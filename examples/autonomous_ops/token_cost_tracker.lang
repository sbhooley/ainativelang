S http cron
Cr L_tick "0 * * * *"  # hourly

# Optional external config from memory
R memory F "config" "token_cost_tracker" ->cfg
X daily_limit_usd (ite cfg (or (cfg.daily_limit_usd) 10.0) 10.0)
X weekly_budget_usd (ite cfg (or (cfg.weekly_budget_usd) 10.0) 10.0)
X alert_threshold (ite cfg (or (cfg.alert_threshold) 0.9) 0.9)

# Configuration
X api_key_env "OPENROUTER_API_KEY"
X usage_url "https://openrouter.ai/api/v1/usage"

# Get OpenRouter usage
X api_key (ops.Env api_key_env))
X headers ({"Authorization":("Bearer "+api_key)})
R http GET usage_url headers ->resp
X status resp.status
X body resp.body
If (core.ne status 200) ->L_fail

X data (parse body)
X now_iso (core.iso)
X today_date (sub now_iso 0 10)

# Compute today’s totals from API
X todays_usage (filter data.usage (lambda u (core.eq (sub u.timestamp 0 10) today_date)))
X day_cost (core.sum (map todays_usage (lambda u (u.cost or 0))))
X total_tokens (core.sum (map todays_usage (lambda u (u.tokens or 0))))
X total_prompt (core.sum (map todays_usage (lambda u (u.prompt_tokens or 0))))
X total_completion (core.sum (map todays_usage (lambda u (u.completion_tokens or 0))))

# Persist today’s summary to memory with 7-day TTL (for rolling windows)
X record_id (core.join ["tok-", today_date, "-", now_iso])
X payload ({
  "date":today_date,
  "cost_usd":day_cost,
  "total_tokens":total_tokens,
  "total_prompt":total_prompt,
  "total_completion":total_completion,
  "ts":now_iso
})
R memory.put "workflow" "workflow.token_cost_state" record_id payload 604800 ->_

# Compute rolling 7‑day totals using server‑side filtering
X week_ago_iso (core.sub now_iso 0 7)
R memory.list "workflow" "workflow.token_cost_state" "" week_ago_iso ->mems
X stored_items mems.items
X stored_week_cost (core.sum (map stored_items (lambda i (i.record_id.payload.cost_usd or 0))))
X stored_week_tokens (core.sum (map stored_items (lambda i (i.record_id.payload.total_tokens or 0))))

X week_cost (core.add stored_week_cost day_cost)
X week_tokens (core.add stored_week_tokens total_tokens)
X pct_used (core.div week_cost weekly_budget_usd)

# Determine alerts
X daily_exceeded (core.gt day_cost daily_limit_usd)
X weekly_over (core.gt pct_used alert_threshold)

# Build summary metrics object (shared)
X summary_metrics ({
  "date": today_date,
  "cost_usd": day_cost,
  "daily_limit_usd": daily_limit_usd,
  "daily_exceeded": daily_exceeded,
  "week_cost_usd": week_cost,
  "week_tokens": week_tokens,
  "weekly_budget_usd": weekly_budget_usd,
  "pct_used": pct_used,
  "total_tokens": total_tokens,
  "total_prompt": total_prompt,
  "total_completion": total_completion
})

# Send alerts if needed (using envelope)
If daily_exceeded ->L_daily_alert ->L_after_alerts
If weekly_over ->L_weekly_alert ->L_after_alerts
J L_after_alerts

L_daily_alert:
  X alert_payload ({
    "envelope": {"version":"1.0","generated_at":now_iso},
    "module":"token_cost_tracker",
    "status":"alert",
    "ts":now_iso,
    "metrics": summary_metrics,
    "history_24h": {},
    "meta": {}
  })
  R queue Put "notify" alert_payload
  J L_after_alerts

L_weekly_alert:
  X alert_payload ({
    "envelope": {"version":"1.0","generated_at":now_iso},
    "module":"token_cost_tracker",
    "status":"alert",
    "ts":now_iso,
    "metrics": summary_metrics,
    "history_24h": {},
    "meta": {}
  })
  R queue Put "notify" alert_payload
  J L_after_alerts

L_fail:
  X fail_payload ({
    "envelope": {"version":"1.0","generated_at":now_iso},
    "module":"token_cost_tracker",
    "status":"alert",
    "ts":now_iso,
    "metrics": {"http_status": status, "error": "failed to fetch usage"},
    "history_24h": {},
    "meta": {}
  })
  R queue Put "notify" fail_payload
  X _ (cache.set "monitor_heartbeat" "token_cost_tracker" now_iso)
  Ret null

L_after_alerts:
  X overall_status (core.ite (core.or daily_exceeded weekly_over) "alert" "ok")
  X summary_payload ({
    "envelope": {"version":"1.0","generated_at":now_iso},
    "module":"token_cost_tracker",
    "status": overall_status,
    "ts":now_iso,
    "metrics": summary_metrics,
    "history_24h": {},
    "meta": {}
  })
  R queue Put "notify" summary_payload
  X _ (cache.set "monitor_heartbeat" "token_cost_tracker" now_iso)
  Ret null
