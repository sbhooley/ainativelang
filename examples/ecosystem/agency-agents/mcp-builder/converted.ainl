# Imported from Markdown (agent) — parsed Agency-Agents-style graph.
# Source: https://raw.githubusercontent.com/msitarzewski/agency-agents/main/specialized/specialized-mcp-builder.md
# Personality / tone: Builds the tools that make AI agents actually useful in the real world.

L_entry:
  R core.parse "{\"kind\":\"agent_entry\",\"slug\":\"mcp-builder\",\"identity\":\"MCP Builder\\nExpert Model Context Protocol developer who designs, builds, and tests MCP servers that extend AI agent capabilities with custom tools, resources, and prompts.\",\"mission\":\"\",\"tone\":\"Builds the tools that make AI agents actually useful in the real world.\"}" ->agent_ctx
  If (core.eq 1 1) ->L_check_rules ->L_exit

L_check_rules:
  R core.parse "{\"kind\":\"rules_gate\",\"text\":\"1. **Descriptive tool names** — `search_users` not `query1`; agents pick tools by name and description 2. **Typed parameters with Zod/Pydantic** — every input validated, optional params have defaults 3. **Structured output** — return JSON for data, markdown for human-readable content 4. **Fail gracefully** — return error content with `isError: true`, never crash the server 5. **Stateless tools** —\"}" ->rules_ctx
  R cache set "md_import" "mcp-builder/rules" rules_ctx ->_cr
  If (core.eq 1 1) ->L_check_deliverables ->L_exit

L_check_deliverables:
  R core.parse "{\"kind\":\"deliverables_gate\",\"text\":\"(unspecified)\"}" ->del_ctx
  If (core.eq 1 1) ->L_workflows_hint ->L_exit

L_workflows_hint:
  R core.parse "{\"kind\":\"workflows_hint\",\"text\":\"(see source doc)\"}" ->wf_ctx
  J wf_ctx

L_exit:
  J "markdown_import_agent_ok"
