# Imported from Markdown (workflow) — parsed Clawflows-style graph.
# Source: local:morning-briefing/original.md
# Workflow: morning-journal
# Schedule → cron: 0 9 * * * (default daily)

S core cron "0 9 * * *"

L_cron:
  Call L_step_1 ->_r1
  Call L_step_2 ->_r2
  Call L_step_3 ->_r3
  Call L_step_4 ->_r4
  Call L_step_5 ->_r5
  Call L_step_6 ->_r6
  Call L_step_7 ->_r7
  Call L_emit_queue ->_rq
  If (core.eq 1 1) ->L_exit ->L_exit

L_step_1:
  R core.parse "{\"step\":1,\"title\":\"Set Up\",\"workflow\":\"morning-journal\",\"source\":\"md_import\"}" ->step_payload
  R core.now ->now
  R core.parse "{\"source\":\"md_import\",\"workflow\":\"morning-journal\",\"confidence\":1.0,\"tags\":[\"clawflow\",\"morning-journal\",\"md_import\"]}" ->memory_meta
  R memory put "workflow" "morning-journal" "step_1" step_payload 3600 memory_meta ->_m1
  J step_payload

