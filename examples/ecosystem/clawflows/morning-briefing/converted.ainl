  R core.now ->now
  R core.parse "{\"source\":\"md_import\",\"workflow\":\"morning-journal\",\"confidence\":1.0,\"tags\":[\"clawflow\",\"morning-journal\",\"md_import\"]}" ->memory_meta
  R memory put "workflow" "morning-journal" "step_5" step_payload 3600 memory_meta ->_m5
