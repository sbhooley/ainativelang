  "target_agent": "openclaw.monitor",
  "target_role": "executor",
  "task_type": "execute_monitor",
  "description": "Run infrastructure_watchdog monitor once and report status.",
  "input": {
    "refs": [
      {
        "kind": "ainl_program",
