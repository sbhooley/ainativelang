  },
  "allowed_tools": ["svc", "cache", "queue", "extras"],
  "approval_required": "none",
  "callback": {
    "file_append": "agents/openclaw.monitor/results.jsonl"
  },
  "metadata": {
    "ainl.program_id": "infrastructure_watchdog.v1"
  }
} J L2

