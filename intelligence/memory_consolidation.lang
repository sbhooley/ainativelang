# Memory Consolidation — Terse Format
# ====================================
# Runs daily at 03:30. Scans recent memory/*.md files, extracts high-signal
# lines, converts to terse bullet format (D:/P:/T:/L:/S:), appends to MEMORY.md.
# Pure compute — no LLM calls. Keyword-based extraction only.
#
# Patterns: Loop + If branching + push + core.contains keyword filter.
S core cron "30 3 * * *"

# ── Entry: list memory dir, read existing MEMORY.md ──
L0:
  R core iso ->nowIso
  R fs list "memory" ->files
  X total (core.len files)
  X noFiles (eq total 0)
  If noFiles ->L20 ->L1

# ── Read existing MEMORY.md for dedup ──
L1:
  R fs read "MEMORY.md" ->existingMem
  X existingLower (core.lower existingMem)
  # Filter to .md files only
  X mdFiles (arr)
  Loop files fname ->L2 ->L3

# ── Check if file is .md ──
L2:
  X isMd (core.contains fname ".md")
  If isMd ->L4 ->L5

L4:
  X mdFiles (push mdFiles fname)

L5:
  Set _skip 1

# ── Process each .md file: read lines, extract high-signal ──
L3:
  X fileCount (core.len mdFiles)
  X noMd (eq fileCount 0)
  If noMd ->L20 ->L6

L6:
  X newItems (arr)
  Loop mdFiles mfile ->L7 ->L12

# ── Read one memory file ──
L7:
  X fpath (core.concat "memory/" mfile)
  R fs readlines fpath ->flines
  Loop flines rawLine ->L8 ->L9

# ── Evaluate one line ──
L8:
  X trimLine (core.trim rawLine)
  X lineLen (core.len trimLine)
  X tooShort (lt lineLen 20)
  If tooShort ->L10 ->L11

# ── Keyword check ──
L11:
  X lower (core.lower trimLine)
  # High-signal keyword detection
  X k1 (core.contains lower "important")
  X k2 (core.contains lower "fixed")
  X k3 (core.contains lower "config")
  X k4 (core.contains lower "preference")
  X k5 (core.contains lower "todo")
  X k6 (core.contains lower "lesson")
  X k7 (core.contains lower "setting")
  X k8 (core.contains lower "requires")
  X k9 (core.contains lower "changed")
  X k10 (core.contains lower "created")
  X k11 (core.contains lower "enabled")
  X k12 (core.contains lower "disabled")
  # Check for existing terse prefixes
  X hasD (core.contains trimLine "D: ")
  X hasP (core.contains trimLine "P: ")
  X hasT (core.contains trimLine "T: ")
  X hasL (core.contains trimLine "L: ")
  X hasS (core.contains trimLine "S: ")
  X isTerse (or hasD (or hasP (or hasT (or hasL hasS))))
  X hasKeyword (or k1 (or k2 (or k3 (or k4 (or k5 (or k6 (or k7 (or k8 (or k9 (or k10 (or k11 k12)))))))))))
  X isLong (gt lineLen 60)
  X keyAndLong (and hasKeyword isLong)
  X keep (or isTerse keyAndLong)
  If keep ->L13 ->L10

# ── Dedup check: skip if already in MEMORY.md ──
L13:
  X alreadyExists (core.contains existingLower lower)
  If alreadyExists ->L10 ->L14

# ── Cap check: stop collecting after 50 items ──
L14:
  X curCount (core.len newItems)
  X atCap (gte curCount 50)
  If atCap ->L10 ->L14b

# ── Classify and add prefix ──
L14b:
  # Already terse? Add as-is
  If isTerse ->L15 ->L16

L15:
  X newItems (push newItems trimLine)

# ── Auto-prefix by keyword type ──
L16:
  X isDecType (or k2 k9)
  X isTodoType (or k5 k8)
  X isLessonType (or k6 k1)
  X isSettType (or k7 (or k3 (or k11 (or k12 k10))))
  # Build prefix via ite chain: D > T > L > S > P
  X p1 (ite isDecType "D: " "")
  X p2 (ite isTodoType "T: " "")
  X p3 (ite isLessonType "L: " "")
  X p4 (ite isSettType "S: " "")
  # Pick first non-empty prefix (priority order)
  X pfxA (ite isDecType p1 (ite isTodoType p2 (ite isLessonType p3 (ite isSettType p4 "P: "))))
  # Truncate to 120 chars max
  X needsTrunc (gt lineLen 120)
  X truncLine (ite needsTrunc (core.substr trimLine 0 120) trimLine)
  X terseLine (core.concat pfxA truncLine)
  X newItems (push newItems terseLine)

# ── No-op skip ──
L10:
  Set _skip 1

# ── After inner loop (per-file) ──
L9:
  Set _done 1

# ── After outer loop: check results ──
L12:
  X itemCount (core.len newItems)
  X noNew (eq itemCount 0)
  If noNew ->L21 ->L17

# ── Write consolidated section to MEMORY.md ──
L17:
  X sectionHeader (core.concat "\n\n## Consolidated — " nowIso "\n")
  X itemText (core.join "\n" newItems)
  X section (core.concat sectionHeader itemText "\n")
  X finalMem (core.concat existingMem section)
  R fs write "MEMORY.md" finalMem ->_
  # Notify
  X countStr (core.stringify itemCount)
  X fileStr (core.stringify fileCount)
  X msg (core.concat "Consolidation: " countStr " terse items from " fileStr " files")
  R queue Put "notify" msg ->_
  J itemCount

# ── Exit: no files ──
L20:
  J 0

# ── Exit: no new items ──
L21:
  J 0
