# Intelligence Digest - runs 3x daily
# Fetches web news, checks TikTok activity, compares to previous run,
# stores a structured record in memory and notifies (QueuePut) on each run.
S core cron "0 8,12,18 * * *"
include "modules/common/generic_memory.ainl" as genmem

L0:
  R core now ->ts
  R web search "(\"U.S. Iran war\" OR \"Strait of Hormuz\" OR \"oil prices\" OR \"ICE\" OR \"Palantir\" OR \"Anthropic\" OR \"Federal Reserve\" OR \"immigration enforcement\" OR \"surveillance AI\") site:reuters.com OR site:apnews.com OR site:bbc.com OR site:iea.org OR site:federalreserve.gov OR site:dhs.gov OR site:ice.gov OR site:palantir.com OR site:anthropic.com OR site:defense.gov OR site:aljazeera.com OR site:dw.com OR site:fr24news.com" ->mentions
  R tiktok recent 24 ->tiktok_recent
  R cache get "digest" "last_mention_count" ->prev_mentions
  R cache get "digest" "last_tiktok_count" ->prev_tiktok

  X mention_count len mentions
  # First run: cache miss resolves to null; compare with literal null token
  X prev_is_none eq prev_mentions null
  If prev_is_none ->L_default_prev ->L_analyze

L_default_prev:
  Set prev_mentions 0
  Set prev_tiktok 0

L_analyze:
  X spike_gt gt mention_count prev_mentions
  X prev_is_zero eq prev_mentions 0
  X is_spike or spike_gt prev_is_zero

  R cache set "digest" "last_mention_count" mention_count ->_
  R cache set "digest" "last_tiktok_count" tiktok_recent ->_

  If is_spike ->L_spike ->L_normal

L_spike:
  R core concat "digest-" ts ->rec_id
  R core concat "{\"mention_count\":" mention_count ",\"tiktok_recent\":" tiktok_recent ",\"spike\":true,\"ts\":" ts "}" ->payload_json
  Set memory_namespace "ops"
  Set memory_kind "intel.digest"
  Set memory_record_id rec_id
  Set memory_payload payload_json
  Set memory_ttl 604800
  Set memory_source "intelligence.intelligence_digest"
  Set memory_tags ["intelligence","digest","ops"]
  Set memory_valid_at ts
  Call genmem/WRITE ->_
  R core concat "Intel digest SPIKE mentions=" mention_count " tiktok=" tiktok_recent ->note
  QueuePut notify note
  R cache set "digest" "last_digest_ts" ts ->_
  J note

L_normal:
  R core concat "digest-" ts ->rec_id
  R core concat "{\"mention_count\":" mention_count ",\"tiktok_recent\":" tiktok_recent ",\"spike\":false,\"ts\":" ts "}" ->payload_json
  Set memory_namespace "ops"
  Set memory_kind "intel.digest"
  Set memory_record_id rec_id
  Set memory_payload payload_json
  Set memory_ttl 604800
  Set memory_source "intelligence.intelligence_digest"
  Set memory_tags ["intelligence","digest","ops"]
  Set memory_valid_at ts
  Call genmem/WRITE ->_
  R core concat "Intel digest OK mentions=" mention_count ->note2
  QueuePut notify note2
  R cache set "digest" "last_digest_ts" ts ->_
  J note2
