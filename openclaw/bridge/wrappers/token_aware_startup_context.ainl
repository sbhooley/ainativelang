# Token-Aware Startup Context Injection
# ======================================
# Reads MEMORY.md line-by-line, selects high-signal lines (decisions,
# preferences, todos, lessons, settings) within a token budget, and writes
# a compact bootstrap file for the next session.
#
# Pure compute — no LLM calls. Runs every 5 minutes.
# Proven patterns: Loop + If branching + push array + J return.
# Includes before S so module labels merge into the prelude.
include "modules/common/generic_memory.ainl" as genmem
include "modules/common/access_aware_memory.ainl" as accmem
include "modules/common/vector_retrieval.ainl" as vec
# S line is only `<adapter> cron "<expr>"` — extra tokens break the schedule (path becomes literal "cron").
S core cron "*/5 * * * *"

# ── Entry: load budget state and gate on remaining tokens ──
L0:
  R cache get "workflow" "token_budget" ->budget_state
  X hasBudget (ne budget_state null)
  If hasBudget ->L1 ->L2

# Use cached budget
L1:
  X tokenCap (get budget_state "daily_remaining")
  X capOk (gt tokenCap 5000)
  If capOk ->L3 ->L10

# No budget cache — use generous default (10 000 tokens)
L2:
  Set tokenCap 10000
  If true ->L3 ->L3

# ── Compute allocation: 10% of remaining, clamped [200..2000] ──
# Opt-in access metadata: touch latest prior snapshot (if any) before building new context
# Filters via core.parse — graph runtime does not execute X {object literal}; see runtime/engine _exec_x.
# Do not use `J L3next` across labels: J resolves a variable and returns (see engine _exec_step J).
L3:
  X filters (core.parse "{\"source\":\"intelligence.token_aware_startup_context\",\"tags_any\":[\"context_injection\",\"workflow\"],\"limit\":1}")
  R memory list "workflow" "workflow.context_injection_snapshot" null "1970-01-01T00:00:00Z" filters ->_snaps
  X snap_items get _snaps "items"
  X snap_len len snap_items
  X no_snap eq snap_len 0
  If no_snap ->L3b ->L3a
L3a:
  X snap0 get snap_items "0"
  X prev_rid get snap0 "record_id"
  Set memory_namespace "workflow"
  Set memory_kind "workflow.context_injection_snapshot"
  Set memory_record_id prev_rid
  Call accmem/LACCESS_READ ->_
  # Use same low allocation as no-snapshot path (ensure budget stays low even with snapshot).
  R core env "AINL_STARTUP_CONTEXT_TOKEN_MIN" 100 ->tokenMin
  R core env "AINL_STARTUP_CONTEXT_TOKEN_MAX" 150 ->tokenMax
  # Use fixed 5% allocation (avoid env-read instability)
  Set pct 0.05
  X raw (mul tokenCap pct)
  X tokenCap (core.clamp raw tokenMin tokenMax)

  # Optional: build candidate lines from embedding top-k (when enabled + non-stub mode).
  R core env "AINL_STARTUP_USE_EMBEDDINGS" "0" ->embFlag
  R core env "AINL_EMBEDDING_MODE" "stub" ->embMode
  X embOn (or (eq embFlag "1") (eq embFlag "true"))
  X embReal (ne embMode "stub")
  X useEmb (and embOn embReal)
  Call L3b_prepare_allLines ->_

  X totalLines (core.len allLines)
  # Initialize accumulators
  X selected (arr)
  Set usedTokens 0
  # Walk lines, collect high-signal ones within budget
  Loop allLines line ->L4 ->L7

L3b:
  # Allocate tokens: 5% of remaining, then clamp (env-tunable).
  R core env "AINL_STARTUP_CONTEXT_TOKEN_MIN" 100 ->tokenMin
  R core env "AINL_STARTUP_CONTEXT_TOKEN_MAX" 150 ->tokenMax
  # Use fixed 5% allocation (avoid env-read instability)
  Set pct 0.05
  X raw (mul tokenCap pct)
  X tokenCap (core.clamp raw tokenMin tokenMax)

  # Optional: build candidate lines from embedding top-k (when enabled + non-stub mode).
  R core env "AINL_STARTUP_USE_EMBEDDINGS" "0" ->embFlag
  R core env "AINL_EMBEDDING_MODE" "stub" ->embMode
  X embOn (or (eq embFlag "1") (eq embFlag "true"))
  X embReal (ne embMode "stub")
  X useEmb (and embOn embReal)
  Call L3b_prepare_allLines ->_

  X totalLines (core.len allLines)
  # Initialize accumulators
  X selected (arr)
  Set usedTokens 0
  # Walk lines, collect high-signal ones within budget
  Loop allLines line ->L4 ->L7

# ── Build allLines (MEMORY.md vs embedding hits) ──
L3b_prepare_allLines:
  If useEmb ->L3b_prepare_emb ->L3b_prepare_fs

L3b_prepare_fs:
  R fs readlines "MEMORY.md" ->allLines
  J 1

L3b_prepare_emb:
  Set vec_query "session startup decisions preferences todos settings"
  Set vec_k 5
  Call vec/VEC_LINES ->allLines
  X hitsLen (core.len allLines)
  X noHits (eq hitsLen 0)
  If noHits ->L3b_prepare_fs ->L3b_emb_after

L3b_emb_after:
  J 1

# ── Per-line evaluation ──
L4:
  X trimmed (core.trim line)
  X lineLen (core.len trimmed)
  # Skip empty or very short lines
  X tooShort (lt lineLen 10)
  If tooShort ->L6 ->L5

# ── Signal detection: terse prefixes, bullet keywords ──
L5:
  X lower (core.lower trimmed)
  # Check for terse bullet prefixes (D: P: T: L: S:)
  X hasD (core.contains lower "d: ")
  X hasP (core.contains lower "p: ")
  X hasT (core.contains lower "t: ")
  X hasL (core.contains lower "l: ")
  X hasS (core.contains lower "s: ")
  X isTerse (or hasD (or hasP (or hasT (or hasL hasS))))
  # Check for keyword signals in longer lines
  X hasBullet (core.contains trimmed "- ")
  X kw1 (core.contains lower "important")
  X kw2 (core.contains lower "fixed")
  X kw3 (core.contains lower "config")
  X kw4 (core.contains lower "preference")
  X kw5 (core.contains lower "todo")
  X kw6 (core.contains lower "lesson")
  X kw7 (core.contains lower "setting")
  X kw8 (core.contains lower "cron")
  X hasKeyword (or kw1 (or kw2 (or kw3 (or kw4 (or kw5 (or kw6 (or kw7 kw8)))))))
  X isLong (gt lineLen 60)
  X keyLine (and isLong hasKeyword)
  X bulletLine (and hasBullet isLong)
  X keep (or isTerse (or keyLine bulletLine))
  If keep ->L8 ->L6

# ── Skip this line (no-op body for Loop) ──
L6:
  Set _skip 1

# ── Budget check and add ──
L8:
  # Estimate tokens: (len + 3) / 4
  X numPlusThree (add lineLen 3)
  X estTokens (core.idiv numPlusThree 4)
  X wouldUse (add usedTokens estTokens)
  X overBudget (gt wouldUse tokenCap)
  If overBudget ->L6 ->L9

# ── Add to selected ──
L9:
  X selected (push selected trimmed)
  Set usedTokens wouldUse

# ── Assemble output ──
L7:
  X count (core.len selected)
  X noResults (eq count 0)
  If noResults ->L10 ->L11

# ── Write bootstrap file ──
L11:
  X body (core.join "\n" selected)
  X output (core.concat "# Session Context (auto-injected)\n" body)
  R fs mkdir ".openclaw/bootstrap" ->_
  R fs write ".openclaw/bootstrap/session_context.md" output ->_
  # Persist stats to cache
  R cache set "workflow" "context_injection_tokens" usedTokens ->_
  R cache set "workflow" "context_injection_lines" count ->_
  R core now ->nowTs
  R cache set "workflow" "context_injection_last" nowTs ->_
  R core iso ->valid_at_iso
  X mem_id (core.concat "ctx-" (core.stringify nowTs))
  X mem_payload (obj "tokens" usedTokens)
  X mem_payload (put mem_payload "lines" count)
  X mem_payload (put mem_payload "generated_at" nowTs)
  Set memory_namespace "workflow"
  Set memory_kind "workflow.context_injection_snapshot"
  Set memory_record_id mem_id
  Set memory_payload mem_payload
  Set memory_ttl 604800
  Set memory_source "intelligence.token_aware_startup_context"
  X memory_tags (arr "intelligence" "context_injection" "workflow")
  Set memory_valid_at valid_at_iso
  Call genmem/WRITE ->_
  J count

# ── Skip: budget too low or no results ──
L10:
  J 0
