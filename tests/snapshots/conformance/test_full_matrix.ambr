                          }
                        },
                        {
                          "type": "object"
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        ''',
      }),
      dict({
        'emitter': 'sql_postgres',
        'output': '''
          -- AINL emitted SQL migration
          -- Source project: AI Native Lang (AINL)
          -- Human initiator: Steven Hooley
          -- Public references: https://x.com/sbhooley | https://stevenhooley.com | https://linkedin.com/in/sbhooley
          -- Provenance docs: docs/PROJECT_ORIGIN_AND_ATTRIBUTION.md | tooling/project_provenance.json
          -- dialect: postgres
  
        ''',
      }),
    ]),
  })
