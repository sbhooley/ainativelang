        '  R core.parse "{\\"n\\":1}" ->record_payload',
        '  R memory put "workflow" "session_budget" "rid1" record_payload 120 memory_meta ->_w',
        '  R memory list "workflow" "session_budget" "rid" "1970-01-01T00:00:00Z" memory_filters ->hist',
        '  R memory prune "workflow" ->_pr',
        '  J hist',
        '',
      ]),
      'text': '''
        # Conformance: memory put → list → prune (session-budget-style workflow namespace).
        # Mirrors patterns used in demo/session_budget_enforcer.lang without http/cache/queue.
        
        L1:
          R core.parse "{\"source\":\"conformance\",\"confidence\":1.0,\"tags\":[\"budget\"],\"valid_at\":\"2026-01-01T00:00:00Z\"}" ->memory_meta
          R core.parse "{\"tags_any\":[\"budget\"],\"source\":\"conformance\",\"limit\":5}" ->memory_filters
          R core.parse "{\"n\":1}" ->record_payload
          R memory put "workflow" "session_budget" "rid1" record_payload 120 memory_meta ->_w
          R memory list "workflow" "session_budget" "rid" "1970-01-01T00:00:00Z" memory_filters ->hist
          R memory prune "workflow" ->_pr
          J hist
  
      ''',
    }),
