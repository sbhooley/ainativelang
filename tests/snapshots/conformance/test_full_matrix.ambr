      'lines': list([
        '# Conformance: memory put → list → prune (session-budget-style workflow namespace).',
        '# Mirrors patterns used in demo/session_budget_enforcer.lang without http/cache/queue.',
        '',
        'L1:',
        '  R core.parse "{\\"source\\":\\"conformance\\",\\"confidence\\":1.0,\\"tags\\":[\\"budget\\"],\\"valid_at\\":\\"2026-01-01T00:00:00Z\\"}" ->memory_meta',
