// Prisma schema generated from D (Data) ops

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id  Int
  name  String
  price  Float
  sku  String
}

model Order {
  id  Int
  uid  Int
  total  Float
  status  String
}

model Customer {
  id  Int
  email  String
  name  String
}

