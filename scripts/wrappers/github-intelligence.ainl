S app core noop

L0:
  # Fetch recent GitHub events (last 4h) via LLM
  R core iso_ts (core.now) ->now_ts
  X cutoff (core.sub now_ts 14400)
  R llm.CHAT "openrouter/quasar-alpha:free" {
    "model": "openrouter/quasar-alpha:free",
    "messages": [
      { "role": "system", "content": "You analyze GitHub events for an AI agent framework (AINL). Extract structured data: actor login, event type (Watch/Star, Fork, Issue opened, PR opened, Comment), repo full_name, created_at (ISO), PR/issue number, title, URL, stars_added? (if implicit). Return JSON array." },
      { "role": "user", "content": core.concat "Fetch the last 100 events from GitHub's public timeline (or trending repos) and summarize key activity related to AI agent frameworks (langchain, crewai, autogen, openagents, aial, ains, etc). Output JSON array of events." }
    ]
  } ->llm_resp
  J llm_resp

L1:
  X content get arg "choices"[0] "message" "content"
  R core.PARSE content ->events
  Filter events where (core.gte get event "created_at_ts" get arg "cutoff") ->recent_events
  J recent_events

L2:
  Set all_repos []
  X i 0
  X total (core.len get arg)
  J total

L_event_loop:
  If (core.ge get arg "i" get arg "total") ->L_event_done
  X ev get arg [get arg "i"]
  X repo_item {
    "id": core.concat (get ev "repo" "full_name") "/" (get ev "type"),
    "full_name": get ev "repo" "full_name",
    "type": get ev "type",
    "created_at": get ev "created_at",
    "actor": get ev "actor" "login"
  }
  X new_all_repos (core.append get arg "all_repos" repo_item)
  X new_i (core.add get arg "i" 1)
  J { "all_repos": new_all_repos, "i": new_i, "total": get arg "total" }

L_event_done:
  J get arg "all_repos"

L_dedup_start:
  Set new_repos []
  X i 0
  X total2 (core.len get arg)
  J { "new_repos": new_repos, "i": i, "total2": total2, "all_repos": get arg }

L_dedup_loop:
  If (core.ge get arg "i" get arg "total2") ->L_dedup_done
  X r get arg "all_repos"[get arg "i"]
  X seen_key (core.concat "github_seen:" (get r "id"))
  R memory get "intel" "github_seen" seen_key ->seen_res
  If (get seen_res "found") ->L_next_item ->L_mark_seen
  J { "seen_res": seen_res, "r": r, "i": get arg "i", "total2": get arg "total2", "all_repos": get arg "all_repos", "new_repos": get arg "new_repos" }

L_mark_seen:
  R memory put "intel" "github_seen" (get arg "seen_key") {} ->_
  X new_new_repos (core.append get arg "new_repos" get arg "r")
  X new_i (core.add get arg "i" 1)
  J { "new_repos": new_new_repos, "i": new_i, "total2": get arg "total2", "all_repos": get arg "all_repos" }

L_next_item:
  X new_i (core.add get arg "i" 1)
  J { "new_repos": get arg "new_repos", "i": new_i, "total2": get arg "total2", "all_repos": get arg "all_repos" }

L_dedup_done:
  J get arg "new_repos"

L_check_new:
  X newCount (core.len get arg)
  If (core.eq newCount 0) ->L_none ->L_build_stats
  J { "newCount": newCount }

L_build_stats:
  X engagement (core.len get arg)
  X velocity (core.mul newCount 3600)
  Set stats { "engagement": engagement, "velocity": velocity, "period_hours": 4 }
  J stats

L_store_begin:
  X payload {
    "reposJson": get arg,
    "stats": get arg "stats",
    "source": "github-intelligence",
    "periodHours": 4
  }
  R http.Post "http://127.0.0.1:3000/api/github-intelligence/digests" payload ->resp
  X digest_id get resp "id"
  J digest_id

L_none:
  J "no-new"