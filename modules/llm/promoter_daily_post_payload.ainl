# modules/llm/promoter_daily_post_payload.ainl
# Build JSON text for promoter.maybe_daily_post **payload** (topic, link, optional text).
# Orchestrates: promoter.daily_snippets → promoter.daily_post_prompts → llm.chat (executor bridge JSON)
# → optional draft text. Uses local frame names only (no executor_req_* collision with parent exreq).
#
# Env (optional):
#   PROMOTER_DAILY_TOPIC / PROMOTER_DAILY_LINK — defaults match ainl-x-promoter.ainl
#   PROMOTER_DAILY_SKIP_LLM — "1" skips LLM and sends topic+link only (static body in maybe_daily_post)
#   PROMOTER_DAILY_POST_TEMPERATURE — JSON number fragment for llm.chat (default 0.72)
#
# Frame out (return value): JSON string for the caller to bind to executor_req_payload_json for maybe_daily_post.

include "modules/common/executor_bridge_request.ainl" as pd_br
include "modules/common/promoter_persona_prompt.ainl" as ppp

LENTRY:
  Set force_static null
  X force_static eq pd_force_static 1
  If force_static ->L_pd_static ->L_pd_entry_env

L_pd_entry_env:
  R core.env "PROMOTER_DAILY_SKIP_LLM" "0" ->sk_raw
  R core.parse sk_raw ->sk_n
  Set sk_skip null
  X sk_skip eq sk_n 1
  If sk_skip ->L_pd_static ->L_pd_fetch

L_pd_fetch:
  R core.parse "{}" ->empty
  R core.parse "0" ->pd_llm_ok
  # pd_llm_ok is overwritten by chat response "ok" (boolean). Init as JSON 0, not "false" (avoids strict/parse edge in nested include).
  R bridge.POST promoter.daily_snippets empty ->snip_http
  X d_sn get snip_http body snippets
  R bridge.POST promoter.daily_post_prompts empty ->pr_http
  X d_sys get pr_http body system
  X d_suf get pr_http body user_suffix
  R core.echo "" ->empty_str
  X d_sn2 (ite (eq d_sn null) empty_str d_sn)
  X d_sys2 (ite (eq d_sys null) empty_str d_sys)
  X d_suf2 (ite (eq d_suf null) empty_str d_suf)
  R core.echo "post" ->ppp_mode
  Call ppp/ENTRY ->pd_persona
  R core.concat d_sys2 "\n\n" ->pd_sys_a
  R core.concat pd_sys_a pd_persona ->pd_sys_with_persona
  R core.concat d_suf2 "\n\n" ->pd_suf_a
  R core.concat pd_suf_a pd_persona ->pd_suf_with_persona
  Set pd_has_persona null
  X pd_has_persona ne pd_persona ""
  X d_sys3 (ite pd_has_persona pd_sys_with_persona d_sys2)
  X d_suf3 (ite pd_has_persona pd_suf_with_persona d_suf2)
  R core.env "PROMOTER_DAILY_TOPIC" "AINL + OpenClaw deterministic graphs" ->d_topic
  R core.env "PROMOTER_DAILY_LINK" "https://github.com/sbhooley/ainativelang" ->d_link
  R core.concat "Topic: " d_topic ->pd_a
  R core.concat pd_a "\nLink: " ->pd_b
  R core.concat pd_b d_link ->pd_c
  R core.concat pd_c "\n\nRepository excerpts:\n" ->pd_d
  R core.concat pd_d d_sn2 ->pd_e
  R core.concat pd_e "\n\n" ->pd_f
  R core.concat pd_f d_suf3 ->daily_user_full
  R core.stringify d_sys3 ->sys_j
  R core.stringify daily_user_full ->usr_j
  R core.concat "{\"role\":\"system\",\"content\":" sys_j "}" ->m0
  R core.concat "{\"role\":\"user\",\"content\":" usr_j "}" ->m1
  R core.concat "[" m0 "," m1 "]" ->msgs
  R core.env "PROMOTER_DAILY_POST_TEMPERATURE" "0.72" ->dtemp
  R core.concat "{\"messages\":" msgs ",\"temperature\":" dtemp ",\"usage_context\":\"daily_original_post\"}" ->pd_llm_inner_json
  R core.stringify "ainl-x-promoter" ->pd_rid_j
  R core.stringify "daily" ->pd_sid_j
  R core.stringify "llm.chat" ->pd_ex_j
  R core.add 120 0 ->pd_to_u
  R core.concat "{\"run_id\":" pd_rid_j ",\"step_id\":" pd_sid_j ",\"executor\":" pd_ex_j ",\"payload\":" pd_llm_inner_json ",\"timeout_s\":" pd_to_u "}" ->ainl_bridge_request_json
  Call pd_br/ENTRY ->req_chat
  R bridge.POST llm.chat req_chat ->chat_http
  X chat_b get chat_http body
  X pd_llm_ok get chat_b ok
  If pd_llm_ok ->L_pd_ok ->L_pd_static

L_pd_ok:
  X draft_text get chat_b text
  R core.parse "{}" ->mdp
  X mdp put mdp "topic" d_topic
  X mdp put mdp "link" d_link
  X mdp put mdp "text" draft_text
  R core.stringify mdp ->pd_maybe_payload_str
  J pd_maybe_payload_str

L_pd_static:
  R core.env "PROMOTER_DAILY_TOPIC" "AINL + OpenClaw deterministic graphs" ->d_topic_s
  R core.env "PROMOTER_DAILY_LINK" "https://github.com/sbhooley/ainativelang" ->d_link_s
  R core.parse "{}" ->mdp2
  X mdp2 put mdp2 "topic" d_topic_s
  X mdp2 put mdp2 "link" d_link_s
  R core.stringify mdp2 ->pd_maybe_payload_str
  J pd_maybe_payload_str

LEXIT_OK:
  J "ok"
LEXIT_FAIL:
  J "err"
