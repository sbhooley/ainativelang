# modules/llm/promoter_process_tweet_payload.ainl
# Build payload object for promoter.process_tweet with persona-aware prompt fields.
#
# Frame in:
#   ppt_tweet (object)
#
# Return:
#   payload object with:
#     payload: tweet object
#     reply_system_prompt: string
#     reply_user_prompt: string
#     reply_fallback_text: string

include "modules/llm/promoter_reply_prompt_bundle.ainl" as prb

LENTRY:
  Set force_static null
  X force_static eq ppt_force_static 1
  If force_static ->L_static ->L_dynamic

L_static:
  Set tweet_use null
  X tweet_use (ite (eq ppt_tweet null) {} ppt_tweet)
  R core.env "PROMOTER_CANONICAL_GITHUB_URL" "https://github.com/sbhooley/ainativelang" ->gh
  R core.concat "AINL keeps agent workflows deterministic and bridge-friendly; this helps teams ship reliable automation. " gh ->reply_fallback_text
  R core.parse "{}" ->out
  R core.parse "\"payload\"" ->k_pay
  R core.parse "\"reply_system_prompt\"" ->k_rsp
  R core.parse "\"reply_user_prompt\"" ->k_rup
  R core.parse "\"reply_fallback_text\"" ->k_rfp
  X out put out k_pay tweet_use
  X out put out k_rsp ""
  X out put out k_rup ""
  X out put out k_rfp reply_fallback_text
  J out

L_dynamic:
  Set tweet_use null
  X tweet_use (ite (eq ppt_tweet null) {} ppt_tweet)
  X tw_text get tweet_use text
  R core.echo "" ->empty_s
  X tw_text2 (ite (eq tw_text null) empty_s tw_text)

  R core.echo "tweet" ->prb_mode
  X prb_text (ite (eq tw_text2 null) "" tw_text2)
  Call prb/ENTRY ->reply_bundle
  R core.parse "\"reply_system_prompt\"" ->k_rsp
  R core.parse "\"reply_user_prompt\"" ->k_rup
  R core.parse "\"reply_fallback_text\"" ->k_rfp
  X reply_system_prompt get reply_bundle k_rsp
  X reply_user_prompt get reply_bundle k_rup
  X reply_fallback_text get reply_bundle k_rfp

  R core.parse "{}" ->out
  R core.parse "\"payload\"" ->k_pay
  X out put out k_pay tweet_use
  X out put out k_rsp reply_system_prompt
  X out put out k_rup reply_user_prompt
  X out put out k_rfp reply_fallback_text
  J out

LEXIT_OK:
  J "ok"
LEXIT_FAIL:
  J "err"
