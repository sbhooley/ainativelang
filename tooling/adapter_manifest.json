{
  "schema_version": "1.1",
  "adapters": {
    "core": {
      "support_tier": "core",
      "strict_contract": true,
      "recommended_lane": "canonical",
      "verbs": [
        "ADD",
        "SUB",
        "MUL",
        "DIV",
        "IDIV",
        "MIN",
        "MAX",
        "CLAMP",
        "CONCAT",
        "FILTER_HIGH_SCORE",
        "SPLIT",
        "JOIN",
        "LOWER",
        "UPPER",
        "REPLACE",
        "CONTAINS",
        "SUBSTR",
        "PARSE",
        "STRINGIFY",
        "NOW",
        "ISO",
        "ISO_TS",
        "ENV",
        "SLEEP",
        "ECHO"
      ],
      "effect_default": "pure",
      "privilege_tier": "pure",
      "destructive": false,
      "network_facing": false,
      "sandbox_safe": true,
      "notes": "Built-in deterministic helper operations."
    },
    "db": {
      "support_tier": "core",
      "strict_contract": true,
      "recommended_lane": "canonical",
      "verbs": ["F", "G", "P", "C", "U", "D"],
      "effect_default": "io",
      "privilege_tier": "local_state",
      "destructive": true,
      "network_facing": false,
      "sandbox_safe": false,
      "notes": "Database CRUD style adapter."
    },
    "api": {
      "support_tier": "compatibility",
      "strict_contract": true,
      "recommended_lane": "noncanonical",
      "verbs": ["G", "P", "POST"],
      "effect_default": "io",
      "privilege_tier": "network",
      "destructive": true,
      "network_facing": true,
      "sandbox_safe": false,
      "notes": "HTTP/API adapter from legacy step forms."
    },
    "email": {
      "support_tier": "extension_openclaw",
      "strict_contract": true,
      "recommended_lane": "canonical",
      "verbs": ["G"],
      "effect_default": "io",
      "privilege_tier": "network",
      "destructive": false,
      "network_facing": true,
      "sandbox_safe": false,
      "notes": "Email provider adapter used by monitoring workflows."
    },
    "calendar": {
      "support_tier": "extension_openclaw",
      "strict_contract": true,
      "recommended_lane": "canonical",
      "verbs": ["G"],
      "effect_default": "io",
      "privilege_tier": "network",
      "destructive": false,
      "network_facing": true,
      "sandbox_safe": false,
      "notes": "Calendar provider adapter used by monitoring workflows."
    },
    "social": {
      "support_tier": "extension_openclaw",
      "strict_contract": true,
      "recommended_lane": "canonical",
      "verbs": ["G"],
      "effect_default": "io",
      "privilege_tier": "network",
      "destructive": false,
      "network_facing": true,
      "sandbox_safe": false,
      "notes": "Social provider adapter used by monitoring workflows."
    },
    "ext": {
      "support_tier": "compatibility",
      "strict_contract": true,
      "recommended_lane": "noncanonical",
      "verbs": ["G", "P", "NEXT", "ECHO", "OP"],
      "effect_default": "io",
      "privilege_tier": "operator_sensitive",
      "destructive": true,
      "network_facing": false,
      "sandbox_safe": false,
      "notes": "External extension adapter namespace used in runtime tests."
    },
    "wasm": {
      "support_tier": "core",
      "strict_contract": true,
      "recommended_lane": "canonical",
      "verbs": ["CALL"],
      "effect_default": "pure",
      "privilege_tier": "pure",
      "destructive": false,
      "network_facing": false,
      "sandbox_safe": true,
      "notes": "Sandboxed compute adapter namespace."
    },
    "cache": {
      "support_tier": "core",
      "strict_contract": true,
      "recommended_lane": "canonical",
      "verbs": ["Get", "Set"],
      "effect_default": "io",
      "privilege_tier": "local_state",
      "destructive": true,
      "network_facing": false,
      "sandbox_safe": true,
      "notes": "Cache namespace used by CacheGet/CacheSet and runtime adapter."
    },
    "queue": {
      "support_tier": "core",
      "strict_contract": true,
      "recommended_lane": "canonical",
      "verbs": ["Put"],
      "effect_default": "io",
      "privilege_tier": "operator_sensitive",
      "destructive": true,
      "network_facing": false,
      "sandbox_safe": false,
      "notes": "Queue write namespace.",
      "result_envelope": {
        "fields": {
          "ok": "bool",
          "message_id": "str|null",
          "queue_name": "str",
          "error": "str|null"
        },
        "notes": "Monitoring-oriented result envelope (descriptive only; runtime behavior unchanged)."
      }
    },
    "txn": {
      "support_tier": "core",
      "strict_contract": true,
      "recommended_lane": "canonical",
      "verbs": ["Begin", "Commit", "Rollback"],
      "effect_default": "io",
      "privilege_tier": "local_state",
      "destructive": true,
      "network_facing": false,
      "sandbox_safe": false,
      "notes": "Transaction namespace."
    },
    "auth": {
      "support_tier": "core",
      "strict_contract": true,
      "recommended_lane": "canonical",
      "verbs": ["Validate"],
      "effect_default": "io",
      "privilege_tier": "operator_sensitive",
      "destructive": false,
      "network_facing": false,
      "sandbox_safe": false,
      "notes": "Authentication namespace."
    },
    "http": {
      "support_tier": "core",
      "strict_contract": true,
      "recommended_lane": "canonical",
      "verbs": ["Get", "Post", "Put", "Patch", "Delete", "Head", "Options"],
      "effect_default": "io",
      "privilege_tier": "network",
      "destructive": true,
      "network_facing": true,
      "sandbox_safe": false,
      "notes": "Runtime HTTP adapter namespace.",
      "result_envelope": {
        "fields": {
          "ok": "bool",
          "status_code": "int|null",
          "error": "str|null",
          "body": "any",
          "headers": "dict|none",
          "url": "str"
        },
        "notes": "Monitoring-oriented HTTP result envelope (descriptive only; runtime behavior unchanged)."
      }
    },
    "bridge": {
      "support_tier": "compatibility",
      "strict_contract": true,
      "recommended_lane": "noncanonical",
      "verbs": ["Post"],
      "effect_default": "io",
      "privilege_tier": "network",
      "destructive": true,
      "network_facing": true,
      "sandbox_safe": false,
      "notes": "Optional config-mapped POST to external executor URLs; same envelope as http.Post. Enable only when host supplies endpoint table.",
      "result_envelope": {
        "fields": {
          "ok": "bool",
          "status_code": "int|null",
          "error": "str|null",
          "body": "any",
          "headers": "dict|none",
          "url": "str"
        },
        "notes": "Delegates to SimpleHttpAdapter; URL is the resolved executor endpoint."
      }
    },
    "sqlite": {
      "support_tier": "core",
      "strict_contract": true,
      "recommended_lane": "canonical",
      "verbs": ["Execute", "Query"],
      "effect_default": "io",
      "privilege_tier": "local_state",
      "destructive": true,
      "network_facing": false,
      "sandbox_safe": true,
      "notes": "Runtime SQLite adapter namespace."
    },
    "fs": {
      "support_tier": "core",
      "strict_contract": true,
      "recommended_lane": "canonical",
      "verbs": ["Read", "Write", "List", "Delete"],
      "effect_default": "io",
      "privilege_tier": "local_state",
      "destructive": true,
      "network_facing": false,
      "sandbox_safe": true,
      "notes": "Runtime filesystem adapter namespace."
    },
    "tools": {
      "support_tier": "core",
      "strict_contract": true,
      "recommended_lane": "canonical",
      "verbs": ["Call"],
      "effect_default": "io",
      "privilege_tier": "operator_sensitive",
      "destructive": true,
      "network_facing": false,
      "sandbox_safe": false,
      "notes": "Runtime tool bridge namespace."
    },
    "svc": {
      "support_tier": "extension_openclaw",
      "strict_contract": false,
      "recommended_lane": "noncanonical",
      "verbs": ["caddy", "cloudflared", "maddy", "crm"],
      "effect_default": "io",
      "privilege_tier": "operator_sensitive",
      "destructive": false,
      "network_facing": true,
      "sandbox_safe": false,
      "notes": "OpenClaw service health adapter used by the monitor demo.",
      "result_envelope": {
        "fields": {
          "ok": "bool",
          "status": "str",
          "latency_ms": "int|null",
          "error": "str|null"
        },
        "notes": "Extension/OpenClaw service health envelope (non-canonical; descriptive only)."
      }
    },
    "extras": {
      "support_tier": "extension_openclaw",
      "strict_contract": false,
      "recommended_lane": "noncanonical",
      "verbs": ["file_exists", "docker_image_exists", "http_status", "newest_backup_mtime", "metrics"],
      "effect_default": "io",
      "privilege_tier": "operator_sensitive",
      "destructive": false,
      "network_facing": true,
      "sandbox_safe": false,
      "notes": "OpenClaw monitor extras adapter for file, Docker, HTTP, backup mtime checks, and metrics summaries."
    },
    "agent": {
      "support_tier": "extension_openclaw",
      "strict_contract": false,
      "recommended_lane": "noncanonical",
      "verbs": ["send_task", "read_result"],
      "effect_default": "io",
      "privilege_tier": "operator_sensitive",
      "destructive": true,
      "network_facing": false,
      "sandbox_safe": false,
      "notes": "Extension/OpenClaw agent coordination adapter for appending AgentTaskRequest envelopes to sandboxed JSONL files under AINL_AGENT_ROOT."
    },
    "tiktok": {
      "support_tier": "extension_openclaw",
      "strict_contract": false,
      "recommended_lane": "noncanonical",
      "verbs": ["F", "recent", "videos"],
      "effect_default": "io",
      "privilege_tier": "network",
      "destructive": false,
      "network_facing": true,
      "sandbox_safe": false,
      "notes": "OpenClaw TikTok monitoring adapter backed by the CRM SQLite database."
    },
    "memory": {
      "support_tier": "extension_openclaw",
      "strict_contract": false,
      "recommended_lane": "noncanonical",
      "verbs": ["put", "get", "append", "list", "delete", "prune"],
      "effect_default": "io",
      "privilege_tier": "local_state",
      "destructive": true,
      "network_facing": false,
      "sandbox_safe": true,
      "recommended_for": "stateful_workflows",
      "notes": "Recommended durable state adapter for any workflow needing persistence across runs. Keyed by (namespace, record_kind, record_id). Extension classification reflects packaging origin, not importance."
    },
    "openclaw_memory": {
      "support_tier": "extension_openclaw",
      "strict_contract": false,
      "recommended_lane": "noncanonical",
      "verbs": ["append_today", "read_today", "search"],
      "effect_default": "io",
      "privilege_tier": "local_state",
      "destructive": true,
      "network_facing": false,
      "sandbox_safe": false,
      "notes": "Append/read OpenClaw-style daily markdown under OPENCLAW_MEMORY_DIR (default workspace memory/) and search via openclaw memory search --json; uses MONITOR_CACHE_JSON for search TTL cache."
    },
    "github": {
      "support_tier": "extension_openclaw",
      "strict_contract": false,
      "recommended_lane": "noncanonical",
      "verbs": ["search_repos", "get_repo", "create_issue"],
      "effect_default": "io",
      "privilege_tier": "network",
      "destructive": true,
      "network_facing": true,
      "sandbox_safe": false,
      "notes": "GitHub REST via requests; optional GITHUB_TOKEN; MONITOR_CACHE_JSON for short-lived GET caching; respects dry_run / AINL_DRY_RUN."
    },
    "crm": {
      "support_tier": "extension_openclaw",
      "strict_contract": false,
      "recommended_lane": "noncanonical",
      "verbs": [
        "create_github_intelligence_digest",
        "find_github_intelligence",
        "upsert_lead"
      ],
      "effect_default": "io",
      "privilege_tier": "network",
      "destructive": true,
      "network_facing": true,
      "sandbox_safe": false,
      "notes": "HTTP to local CRM; default base URL from adapters/openclaw_defaults.py (non-standard port, override CRM_API_BASE). CRM_PATH_* env vars; GET cache for find_github_intelligence; dry_run skips writes."
    },
    "classify": {
      "support_tier": "compatibility",
      "strict_contract": true,
      "recommended_lane": "noncanonical",
      "verbs": ["SCORE_RELEVANCE"],
      "effect_default": "io",
      "privilege_tier": "network",
      "destructive": true,
      "network_facing": true,
      "sandbox_safe": false,
      "notes": "Strict allowlist placeholder for bridge-backed relevance scoring (e.g. apollo-x-bot); implement via gateway or executor bridge."
    },
    "state": {
      "support_tier": "compatibility",
      "strict_contract": true,
      "recommended_lane": "noncanonical",
      "verbs": ["GET_SEEN_IDS", "MARK_SEEN"],
      "effect_default": "io",
      "privilege_tier": "local_state",
      "destructive": true,
      "network_facing": false,
      "sandbox_safe": true,
      "notes": "Strict allowlist placeholder for dedupe / seen-id state (e.g. apollo-x-bot); implement via SQLite or bridge."
    },
    "x": {
      "support_tier": "compatibility",
      "strict_contract": true,
      "recommended_lane": "noncanonical",
      "verbs": ["SEARCH", "POST_REPLY"],
      "effect_default": "io",
      "privilege_tier": "network",
      "destructive": true,
      "network_facing": true,
      "sandbox_safe": false,
      "notes": "Strict allowlist placeholder for X/Twitter-shaped bridge calls; production graphs use bridge.POST with executor keys instead."
    }
  }
}
