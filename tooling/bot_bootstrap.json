{
  "version": "1.0",
  "project": "AINL",
  "description": "Discoverable bootstrap for bots and agents working in the AINL/OpenClaw repo. Pointers only; not an execution engine.",
  "primary_onboarding_doc": "docs/BOT_ONBOARDING.md",
  "implementation_preflight_doc": "docs/OPENCLAW_IMPLEMENTATION_PREFLIGHT.md",
  "docs_index": "docs/DOCS_INDEX.md",
  "openclaw_ainl_gold_standard": "docs/operations/OPENCLAW_AINL_GOLD_STANDARD.md",
  "safe_default_docs": [
    "docs/AINL_SPEC.md",
    "docs/AINL_CANONICAL_CORE.md",
    "docs/EXAMPLE_SUPPORT_MATRIX.md",
    "docs/RUNTIME_COMPILER_CONTRACT.md",
    "docs/architecture/GRAPH_INTROSPECTION.md",
    "docs/reference/IR_SCHEMA.md",
    "docs/reference/GRAPH_SCHEMA.md"
  ],
  "advanced_docs": [
    "docs/adapters/OPENCLAW_ADAPTERS.md",
    "docs/adapters/MEMORY_CONTRACT.md",
    "docs/advanced/SAFE_USE_AND_THREAT_MODEL.md",
    "docs/reference/CAPABILITY_REGISTRY.md",
    "docs/operations/AUTONOMOUS_OPS_MONITORS.md",
    "docs/operations/STANDARDIZED_HEALTH_ENVELOPE.md",
    "docs/advanced/AGENT_COORDINATION_CONTRACT.md"
  ],
  "required_steps": [
    "Inspect relevant current files first",
    "Name the exact files inspected",
    "Confirm the task is not already implemented",
    "Confirm relevant adapter/function semantics from code, not memory",
    "Distinguish confirmed facts from assumptions",
    "Explicitly state any assumption that could break the plan",
    "Prefer the smallest practical change",
    "Avoid inferring payload access from list/enumeration APIs unless code proves it",
    "Provide a validation plan before coding",
    "Choose a different task if the chosen one is already implemented"
  ],
  "expected_output_structure": [
    "chosen_task",
    "why_not_duplicate_work",
    "files_inspected",
    "current_behavior_found",
    "verified_semantics",
    "assumptions",
    "smallest_viable_implementation",
    "validation_plan"
  ]
}
