{
  "schema_version": "1.0",
  "profiles": {
    "local_minimal": {
      "description": "Local or personal development where workflows should not perform external I/O.",
      "intended_use": [
        "graph debugging",
        "authoring and refactoring workflows",
        "dry-run validation without side effects"
      ],
      "adapter_allowlist": ["core"],
      "forbidden_adapters": [],
      "forbidden_effects": ["io", "io-read", "io-write"],
      "forbidden_effect_tiers": [],
      "forbidden_privilege_tiers": ["local_state", "network", "operator_sensitive"],
      "runtime_limits": {
        "max_steps": 500,
        "max_depth": 10,
        "max_adapter_calls": 0,
        "max_time_ms": 5000
      },
      "orchestrator_expectations": [
        "enforce container or process isolation if untrusted code is present",
        "no outbound network connectivity required"
      ]
    },
    "sandbox_compute_and_store": {
      "description": "Sandboxed/containerized environment with local compute and storage but no outbound network.",
      "intended_use": [
        "offline or air-gapped environments",
        "restricted containers with local-only storage",
        "stateful workflows without network access"
      ],
      "adapter_allowlist": ["core", "sqlite", "fs", "wasm", "memory", "cache"],
      "forbidden_adapters": ["http", "postgres", "mysql", "redis", "dynamodb", "airtable", "supabase", "agent", "svc", "extras", "tiktok", "email", "calendar", "social", "queue", "tools", "db"],
      "forbidden_effects": [],
      "forbidden_effect_tiers": [],
      "forbidden_privilege_tiers": ["network", "operator_sensitive"],
      "runtime_limits": {
        "max_steps": 5000,
        "max_depth": 50,
        "max_adapter_calls": 500,
        "max_time_ms": 30000
      },
      "orchestrator_expectations": [
        "block outbound network at the container or network layer",
        "mount local storage in a dedicated sandbox root",
        "provide per-container CPU/memory/time limits"
      ]
    },
    "sandbox_network_restricted": {
      "description": "Sandboxed/containerized environment with controlled outbound network access.",
      "intended_use": [
        "operator-controlled runtimes with limited network egress",
        "workloads that must call a small set of approved HTTP APIs"
      ],
      "adapter_allowlist": ["core", "sqlite", "postgres", "mysql", "redis", "dynamodb", "airtable", "supabase", "fs", "wasm", "memory", "cache", "http", "tools", "queue"],
      "forbidden_adapters": ["agent", "svc", "extras", "tiktok", "email", "calendar", "social"],
      "forbidden_effects": [],
      "forbidden_effect_tiers": [],
      "forbidden_privilege_tiers": ["operator_sensitive"],
      "runtime_limits": {
        "max_steps": 5000,
        "max_depth": 50,
        "max_adapter_calls": 500,
        "max_time_ms": 30000
      },
      "orchestrator_expectations": [
        "enforce HTTP host allowlists (e.g. api.internal.example.com) at network or adapter config level",
        "set container-level resource limits",
        "treat AINL as a workflow engine, not a primary security boundary"
      ]
    },
    "consumer_secure_default": {
      "description": "Product-friendly strict preset: common data/HTTP/web/LLM adapters; blocks operator-only integrations. Used when AINL_STRICT_MODE=1 without AINL_SECURITY_PROFILE (merged with host resource floors).",
      "intended_use": [
        "consumer apps and hosted sandboxes",
        "environments that want a named allowlist without hand-maintaining adapter lists"
      ],
      "adapter_allowlist": [
        "core",
        "sqlite",
        "postgres",
        "mysql",
        "redis",
        "dynamodb",
        "airtable",
        "supabase",
        "fs",
        "wasm",
        "memory",
        "cache",
        "http",
        "web",
        "llm",
        "llm_query",
        "tools",
        "queue"
      ],
      "forbidden_adapters": [
        "agent",
        "svc",
        "extras",
        "tiktok",
        "email",
        "calendar",
        "social"
      ],
      "forbidden_effects": [],
      "forbidden_effect_tiers": [],
      "forbidden_privilege_tiers": ["operator_sensitive"],
      "runtime_limits": {
        "max_steps": 5000,
        "max_depth": 50,
        "max_adapter_calls": 500,
        "max_time_ms": 30000
      },
      "orchestrator_expectations": [
        "merge with deployment max_steps/max_time floors so consumer apps stay bounded",
        "pair with HTTP host allowlists at the adapter or network layer"
      ]
    },
    "operator_full": {
      "description": "Operator-controlled environment with full adapter surface enabled by explicit choice.",
      "intended_use": [
        "trusted operator-managed deployments",
        "OpenClaw-style platform environments",
        "environments where an external policy engine and approvals are already in place"
      ],
      "adapter_allowlist": "operator_defined",
      "forbidden_adapters": [],
      "forbidden_effects": [],
      "forbidden_effect_tiers": [],
      "forbidden_privilege_tiers": [],
      "runtime_limits": {
        "max_steps": 50000,
        "max_depth": 200,
        "max_adapter_calls": 5000,
        "max_time_ms": 300000
      },
      "orchestrator_expectations": [
        "provide its own policy/approval engine",
        "control network egress and secrets",
        "decide which adapters to enable per deployment",
        "treat extension_openclaw adapters as operator-only"
      ]
    },
    "ptc_sandbox_plus": {
      "description": "Sandboxed profile for optional PTC/LLM reliability adapters with strict limits.",
      "intended_use": [
        "ptc_runner integration testing",
        "signature-enforced agent workflows",
        "limited external orchestration"
      ],
      "adapter_allowlist": ["core", "memory", "cache", "ptc_runner", "llm_query"],
      "forbidden_adapters": ["fs", "sqlite", "tools", "agent", "svc", "extras", "tiktok", "email", "calendar", "social"],
      "forbidden_effects": [],
      "forbidden_effect_tiers": [],
      "forbidden_privilege_tiers": ["operator_sensitive"],
      "runtime_limits": {
        "max_steps": 3000,
        "max_depth": 30,
        "max_adapter_calls": 300,
        "max_time_ms": 30000,
        "max_subagent_budget": 10,
        "trace_depth": 200,
        "max_concurrent_calls": 10
      },
      "orchestrator_expectations": [
        "enable only explicit endpoints for ptc_runner/llm_query via host allowlists",
        "treat underscore-prefixed context keys as private and non-exportable",
        "run signature_enforcer for post-execution validation"
      ]
    }
  }
}
