# Token Usage Tracker - hourly
# Fetches OpenRouter usage, tracks daily + weekly costs, alerts on thresholds.
S http cron "0 * * * *"
include "modules/common/token_cost_memory.ainl" as tokenmem

L0:
  R core now ->ts
  R core iso ->now_iso
  R cache get "config" "token_daily_limit" ->cfg_daily
  R cache get "config" "token_weekly_budget" ->cfg_weekly
  R cache get "config" "token_alert_threshold" ->cfg_threshold

  X daily_limit eq cfg_daily 0
  If daily_limit ->L_use_default_daily ->L_has_daily
L_use_default_daily:
  Set daily_limit_usd 10.0
  J L_check_weekly
L_has_daily:
  Set daily_limit_usd cfg_daily

L_check_weekly:
  X weekly_unset eq cfg_weekly 0
  If weekly_unset ->L_use_default_weekly ->L_has_weekly
L_use_default_weekly:
  Set weekly_budget_usd 10.0
  J L_check_thresh
L_has_weekly:
  Set weekly_budget_usd cfg_weekly

L_check_thresh:
  X thresh_unset eq cfg_threshold 0
  If thresh_unset ->L_use_default_thresh ->L_has_thresh
L_use_default_thresh:
  Set alert_threshold 0.9
  J L_fetch
L_has_thresh:
  Set alert_threshold cfg_threshold

L_fetch:
  R http GET "https://openrouter.ai/api/v1/usage" {"Authorization":"Bearer placeholder"} ->resp
  X status_code get resp "status"
  X is_ok eq status_code 200
  If is_ok ->L_parse ->L_fail

L_parse:
  R core stringify resp ->body_str
  R core parse body_str ->data

  # Store today's snapshot in memory for weekly rollup
  R core concat "tok-" now_iso ->record_id
  R core concat "{\"date\":\"" now_iso "\",\"ts\":" ts "}" ->day_payload
  Set memory_kind "workflow.token_cost_state"
  Set memory_record_id record_id
  Set memory_payload day_payload
  Set memory_ttl 604800
  Set memory_source "demo.token_cost_tracker"
  Set memory_tags ["token_cost","monitor","workflow"]
  Set memory_valid_at now_iso
  Call tokenmem/WRITE ->_

  # Query 7-day history for weekly rollup
  R core iso_ts ->week_ago
  Set memory_updated_after week_ago
  Set memory_list_limit 500
  Call tokenmem/LIST ->hist
  X week_count len hist

  # Build and send summary
  R core concat "📊 Token Usage — " now_iso "\n\nDaily limit: $" daily_limit_usd "\nWeekly budget: $" weekly_budget_usd "\n7-day records: " week_count ->summary
  QueuePut notify summary
  R cache set "monitor_heartbeat" "token_cost_tracker" ts ->_
  Ret null

L_fail:
  R core concat "⚠️ Token tracker: HTTP " status_code " fetching usage" ->fail_msg
  QueuePut notify fail_msg
  R cache set "monitor_heartbeat" "token_cost_tracker" ts ->_
  Ret null
