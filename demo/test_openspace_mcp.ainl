# test_openspace_mcp.ainl
# Quick test that OpenSpace MCP tools are callable via HTTP

S app core noop

L_test:
  R http.POST "http://localhost:8080/mcp/execute_task" {"task": "Say hello and confirm you are working from OpenSpace MCP.", "search_scope": "local", "max_iterations": 5} ->mcp_result
  J mcp_result
