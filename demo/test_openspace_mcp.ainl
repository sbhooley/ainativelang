# test_openspace_mcp.ainl
# Quick test that OpenSpace MCP tools are callable

S core now ->L0

L0:
  J L_test
  ->L_done

L_test:
  R mcp.openspace.execute_task
    task="Say hello and confirm you are working from OpenSpace MCP."
    search_scope="local"
    max_iterations=5
  ->mcp_result
  Ret mcp_result

L_done:
  Ret {"skipped": true}
