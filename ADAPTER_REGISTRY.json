{
  "$schema": "https://ainl.dev/registry/v1",
  "description": "Machine-readable catalog of AINL adapters for OpenClaw integration",
  "adapters": {
    "core": {
      "description": "Built-in arithmetic, string, date/time, and control utilities",
      "targets": {
        "add": {
          "args": [
            "number",
            "number"
          ],
          "returns": "number",
          "pure": true
        },
        "sub": {
          "args": [
            "number",
            "number"
          ],
          "returns": "number",
          "pure": true
        },
        "mul": {
          "args": [
            "number",
            "number"
          ],
          "returns": "number",
          "pure": true
        },
        "div": {
          "args": [
            "number",
            "number"
          ],
          "returns": "number",
          "pure": true
        },
        "min": {
          "args": [
            "any..."
          ],
          "returns": "any",
          "pure": true
        },
        "max": {
          "args": [
            "any..."
          ],
          "returns": "any",
          "pure": true
        },
        "clamp": {
          "args": [
            "number",
            "number",
            "number"
          ],
          "returns": "number",
          "pure": true
        },
        "concat": {
          "args": [
            "string..."
          ],
          "returns": "string",
          "pure": true
        },
        "split": {
          "args": [
            "string",
            "string"
          ],
          "returns": "[string]",
          "pure": true
        },
        "join": {
          "args": [
            "string",
            "[string]"
          ],
          "returns": "string",
          "pure": true
        },
        "lower": {
          "args": [
            "string"
          ],
          "returns": "string",
          "pure": true
        },
        "upper": {
          "args": [
            "string"
          ],
          "returns": "string",
          "pure": true
        },
        "replace": {
          "args": [
            "string",
            "string",
            "string"
          ],
          "returns": "string",
          "pure": true
        },
        "contains": {
          "args": [
            "string",
            "string"
          ],
          "returns": "boolean",
          "pure": true
        },
        "parse": {
          "args": [
            "string"
          ],
          "returns": "any",
          "pure": true
        },
        "stringify": {
          "args": [
            "any"
          ],
          "returns": "string",
          "pure": true
        },
        "now": {
          "args": [],
          "returns": "number",
          "pure": true
        },
        "iso": {
          "args": [],
          "returns": "string",
          "pure": true
        },
        "sleep": {
          "args": [
            "number"
          ],
          "returns": "null",
          "side_effect": "blocks"
        }
      }
    },
    "http": {
      "description": "HTTP client with host allowlist and response size limits",
      "targets": {
        "GET": {
          "args": [
            "url",
            "headers?"
          ],
          "returns": "{status, headers, body}",
          "network": true
        },
        "POST": {
          "args": [
            "url",
            "body?",
            "headers?",
            "timeout?"
          ],
          "returns": "{status, headers, body}",
          "network": true
        },
        "PUT": {
          "args": [
            "url",
            "body?",
            "headers?",
            "timeout?"
          ],
          "returns": "{status, headers, body}",
          "network": true
        },
        "PATCH": {
          "args": [
            "url",
            "body?",
            "headers?",
            "timeout?"
          ],
          "returns": "{status, headers, body}",
          "network": true
        },
        "DELETE": {
          "args": [
            "url",
            "headers?",
            "timeout?"
          ],
          "returns": "{status, headers, body}",
          "network": true
        },
        "HEAD": {
          "args": [
            "url",
            "headers?",
            "timeout?"
          ],
          "returns": "{status, headers, body}",
          "network": true
        },
        "OPTIONS": {
          "args": [
            "url",
            "headers?",
            "timeout?"
          ],
          "returns": "{status, headers, body}",
          "network": true
        }
      },
      "config": {
        "default_timeout_s": 5.0,
        "max_response_bytes": 1000000,
        "allow_hosts": []
      },
      "notes": [
        "Performs up to 3 attempts with small exponential backoff on transport errors (URLError/timeouts) and 5xx HTTP status codes.",
        "Does not retry 4xx client errors; those fail immediately with a status error."
      ]
    },
    "sqlite": {
      "description": "SQLite database access with optional table allowlist",
      "targets": {
        "query": {
          "args": [
            "sql",
            "params?"
          ],
          "returns": "[row]",
          "pure": false
        },
        "execute": {
          "args": [
            "sql",
            "params?"
          ],
          "returns": "{rows_affected, lastrowid}",
          "pure": false
        }
      },
      "config": {
        "db_path": "required",
        "allow_write": false,
        "allow_tables": [],
        "timeout_s": 5.0
      },
      "rules": [
        "query target requires SELECT statements",
        "execute target requires DML/DDL",
        "table allowlist enforced by regex"
      ]
    },
    "postgres": {
      "description": "PostgreSQL database access with allowlist and transaction support",
      "privilege_tier": "network",
      "destructive": true,
      "network_facing": true,
      "sandbox_safe": false,
      "async_capable": true,
      "targets": {
        "query": {
          "args": [
            "sql",
            "params?"
          ],
          "returns": "[row]",
          "pure": false
        },
        "execute": {
          "args": [
            "sql",
            "params?"
          ],
          "returns": "{rows_affected, lastrowid}",
          "pure": false
        },
        "transaction": {
          "args": [
            "[{verb, sql, params?}]"
          ],
          "returns": "{ok, results}",
          "pure": false
        }
      },
      "config": {
        "url_env": "AINL_POSTGRES_URL",
        "host_env": "AINL_POSTGRES_HOST",
        "port_env": "AINL_POSTGRES_PORT",
        "db_env": "AINL_POSTGRES_DB",
        "user_env": "AINL_POSTGRES_USER",
        "password_env": "AINL_POSTGRES_PASSWORD",
        "sslmode_env": "AINL_POSTGRES_SSLMODE (default: require)",
        "sslrootcert_env": "AINL_POSTGRES_SSLROOTCERT (optional CA bundle path)",
        "pool_min_env": "AINL_POSTGRES_POOL_MIN (default: 1)",
        "pool_max_env": "AINL_POSTGRES_POOL_MAX (default: 5)",
        "runtime_async_env": "AINL_RUNTIME_ASYNC (or --runtime-async)",
        "timeout_s": 5.0,
        "statement_timeout_ms": 5000,
        "allow_write": false,
        "allow_tables": []
      },
      "rules": [
        "query target requires SELECT/CTE statements",
        "execute target requires DML/DDL and allow_write=true",
        "transaction executes ordered query/execute operations atomically",
        "parameterized queries are required for untrusted inputs"
      ]
    },
    "mysql": {
      "description": "MySQL database access with allowlist and transaction support",
      "privilege_tier": "network",
      "destructive": true,
      "network_facing": true,
      "sandbox_safe": false,
      "async_capable": true,
      "targets": {
        "query": {
          "args": [
            "sql",
            "params?"
          ],
          "returns": "[row]",
          "pure": false
        },
        "execute": {
          "args": [
            "sql",
            "params?"
          ],
          "returns": "{rows_affected, lastrowid}",
          "pure": false
        },
        "transaction": {
          "args": [
            "[{verb, sql, params?}]"
          ],
          "returns": "{ok, results}",
          "pure": false
        }
      },
      "config": {
        "url_env": "AINL_MYSQL_URL",
        "host_env": "AINL_MYSQL_HOST",
        "port_env": "AINL_MYSQL_PORT",
        "db_env": "AINL_MYSQL_DB",
        "user_env": "AINL_MYSQL_USER",
        "password_env": "AINL_MYSQL_PASSWORD",
        "ssl_mode_env": "AINL_MYSQL_SSL_MODE (default: REQUIRED)",
        "ssl_ca_env": "AINL_MYSQL_SSL_CA (optional CA bundle path)",
        "pool_min_env": "AINL_MYSQL_POOL_MIN (default: 1)",
        "pool_max_env": "AINL_MYSQL_POOL_MAX (default: 5)",
        "runtime_async_env": "AINL_RUNTIME_ASYNC (or --runtime-async)",
        "timeout_s": 5.0,
        "allow_write": false,
        "allow_tables": []
      },
      "rules": [
        "query target requires SELECT/CTE statements",
        "execute target requires DML/DDL and allow_write=true",
        "transaction executes ordered query/execute operations atomically",
        "parameterized queries are required for untrusted inputs"
      ]
    },
    "redis": {
      "description": "Redis cache/session/queue/pubsub access with optional key-prefix policy",
      "privilege_tier": "network",
      "destructive": true,
      "network_facing": true,
      "sandbox_safe": false,
      "async_capable": true,
      "targets": {
        "get": {"args": ["key"], "returns": "string|null", "pure": false},
        "set": {"args": ["key", "value", "ttl_s?"], "returns": "{ok}", "pure": false},
        "delete": {"args": ["key"], "returns": "{deleted}", "pure": false},
        "incr": {"args": ["key", "amount?"], "returns": "number", "pure": false},
        "decr": {"args": ["key", "amount?"], "returns": "number", "pure": false},
        "hget": {"args": ["key", "field"], "returns": "string|null", "pure": false},
        "hset": {"args": ["key", "field", "value"], "returns": "{updated}", "pure": false},
        "hdel": {"args": ["key", "field"], "returns": "{deleted}", "pure": false},
        "hmget": {"args": ["key", "[fields]"], "returns": "[value]", "pure": false},
        "lpush": {"args": ["key", "value"], "returns": "number", "pure": false},
        "rpush": {"args": ["key", "value"], "returns": "number", "pure": false},
        "lpop": {"args": ["key"], "returns": "value|null", "pure": false},
        "rpop": {"args": ["key"], "returns": "value|null", "pure": false},
        "llen": {"args": ["key"], "returns": "number", "pure": false},
        "publish": {"args": ["channel", "message"], "returns": "{subscribers}", "pure": false},
        "subscribe": {"args": ["channel", "timeout_s?", "max_messages?"], "returns": "{channel, messages}", "pure": false},
        "ping": {"args": [], "returns": "bool|string", "pure": false},
        "info": {"args": ["section?"], "returns": "{...}", "pure": false},
        "transaction": {"args": ["[{verb, args}]"], "returns": "{ok, results}", "pure": false}
      },
      "config": {
        "url_env": "AINL_REDIS_URL",
        "host_env": "AINL_REDIS_HOST",
        "port_env": "AINL_REDIS_PORT",
        "db_env": "AINL_REDIS_DB",
        "user_env": "AINL_REDIS_USER",
        "password_env": "AINL_REDIS_PASSWORD",
        "ssl_env": "AINL_REDIS_SSL",
        "runtime_async_env": "AINL_RUNTIME_ASYNC (or --runtime-async)",
        "timeout_s": 5.0,
        "allow_write": false,
        "allow_prefixes": []
      },
      "rules": [
        "write verbs require allow_write=true",
        "optional allow_prefixes policy scopes keys/channels",
        "transaction executes ordered redis operations atomically",
        "native async mode uses redis.asyncio for full verb parity with bounded subscribe polling"
      ]
    },
    "dynamodb": {
      "description": "AWS DynamoDB access for item, query/scan, batch, and transactional operations",
      "privilege_tier": "network",
      "destructive": true,
      "network_facing": true,
      "sandbox_safe": false,
      "async_capable": true,
      "targets": {
        "get": {"args": ["table", "key", "consistent_read?"], "returns": "{item}", "pure": false},
        "put": {"args": ["table", "item", "return_values?"], "returns": "{attributes}", "pure": false},
        "update": {"args": ["table", "key", "update_expression", "expression_attribute_values?", "expression_attribute_names?", "return_values?"], "returns": "{attributes}", "pure": false},
        "delete": {"args": ["table", "key", "return_values?"], "returns": "{attributes}", "pure": false},
        "query": {"args": ["table", "key_condition_expression", "expression_attribute_values?", "filter_expression?", "limit?", "exclusive_start_key?"], "returns": "{items, count, last_evaluated_key?}", "pure": false},
        "scan": {"args": ["table", "filter_expression?", "expression_attribute_values?", "limit?", "exclusive_start_key?"], "returns": "{items, count, last_evaluated_key?}", "pure": false},
        "batch_get": {"args": ["request_items"], "returns": "{responses}", "pure": false},
        "batch_write": {"args": ["request_items"], "returns": "{ok, unprocessed_items}", "pure": false},
        "transact_get": {"args": ["transact_items"], "returns": "{ok, results}", "pure": false},
        "transact_write": {"args": ["transact_items"], "returns": "{ok, results}", "pure": false},
        "describe_table": {"args": ["table"], "returns": "{table}", "pure": false},
        "list_tables": {"args": ["limit?", "exclusive_start_table_name?"], "returns": "{tables, last_evaluated_table_name?}", "pure": false},
        "streams_subscribe": {"args": ["table_name", "shard_iterator_type?", "filter?", "timeout_s?", "max_events?"], "returns": "{table, events, active}", "pure": false},
        "streams_unsubscribe": {"args": ["table_name"], "returns": "{table, removed}", "pure": false}
      },
      "config": {
        "url_env": "AINL_DYNAMODB_URL (optional, for local endpoint override)",
        "region_env": "AINL_DYNAMODB_REGION (default: us-east-1)",
        "aws_env": "AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY/AWS_SESSION_TOKEN standard chain",
        "runtime_async_env": "AINL_RUNTIME_ASYNC (or --runtime-async)",
        "timeout_s": 5.0,
        "allow_write": false,
        "allow_tables": [],
        "consistent_read": false
      },
      "rules": [
        "mutating verbs require allow_write=true",
        "table allowlist enforced across all table-scoped operations",
        "transact_write and batch_write respect the same write gate",
        "streams.subscribe uses bounded polling with timeout/max_events and follows table allowlist",
        "native async mode supports non-blocking stream batching via background listener tasks"
      ]
    },
    "airtable": {
      "description": "Airtable REST adapter for no-code style table/record workflows",
      "privilege_tier": "network",
      "destructive": true,
      "network_facing": true,
      "sandbox_safe": false,
      "async_capable": true,
      "targets": {
        "list": {"args": ["table", "params?"], "returns": "{records, offset?}", "pure": false},
        "find": {"args": ["table", "formula_or_filter"], "returns": "{records, offset?}", "pure": false},
        "create": {"args": ["table", "record_or_records"], "returns": "{...}", "pure": false},
        "update": {"args": ["table", "record_or_records"], "returns": "{...}", "pure": false},
        "delete": {"args": ["table", "record_id_or_ids"], "returns": "{...}", "pure": false},
        "upsert": {"args": ["table", "key_field", "key_value", "fields"], "returns": "{ok, action, record}", "pure": false},
        "get_table": {"args": ["table"], "returns": "{table}", "pure": false},
        "list_tables": {"args": [], "returns": "{tables}", "pure": false},
        "list_bases": {"args": [], "returns": "{bases, offset?}", "pure": false},
        "attachment_upload": {"args": ["table", "record_id", "field_name", "file_path_or_bytes_or_url", "filename?"], "returns": "{ok, attachment|record}", "pure": false},
        "attachment_download": {"args": ["table", "attachment_url", "output_path?"], "returns": "{bytes_b64|path,size}", "pure": false},
        "webhook_create": {"args": ["table", "table_or_view", "actions", "notification_url"], "returns": "{webhook_id, expiration_time, mac_secret_base64, specification}", "pure": false},
        "webhook_list": {"args": ["table"], "returns": "{webhooks}", "pure": false},
        "webhook_delete": {"args": ["table", "webhook_id"], "returns": "{id, deleted}", "pure": false}
      },
      "config": {
        "api_key_env": "AINL_AIRTABLE_API_KEY",
        "base_id_env": "AINL_AIRTABLE_BASE_ID",
        "runtime_async_env": "AINL_RUNTIME_ASYNC (or --runtime-async)",
        "timeout_s": 8.0,
        "allow_write": false,
        "allow_tables": [],
        "allow_attachment_host_env": "AINL_AIRTABLE_ALLOW_ATTACHMENT_HOST (comma-separated)",
        "max_page_size": 100
      },
      "rules": [
        "mutating verbs require allow_write=true",
        "table allowlist enforced when configured",
        "attachment download/upload-url can be constrained by allow_attachment_hosts",
        "adapter applies bounded retries for rate-limit/transient http failures",
        "webhook registration returns metadata only; webhook payload processing is external to this adapter"
      ]
    },
    "supabase": {
      "description": "Supabase convenience wrapper with Postgres delegation and auth/storage/realtime helpers",
      "privilege_tier": "network",
      "destructive": true,
      "network_facing": true,
      "sandbox_safe": false,
      "targets": {
        "from": {"args": ["table"], "returns": "{ok, table}", "pure": false},
        "select": {"args": ["table", "where?", "columns?"], "returns": "{data, error?}", "pure": false},
        "query": {"args": ["table", "where?", "columns?"], "returns": "{data, error?}", "pure": false},
        "insert": {"args": ["table", "payload"], "returns": "{data, error?}", "pure": false},
        "update": {"args": ["table", "fields", "where"], "returns": "{data, error?}", "pure": false},
        "upsert": {"args": ["table", "payload", "key_fields"], "returns": "{ok, action, data, error?}", "pure": false},
        "delete": {"args": ["table", "where"], "returns": "{data, error?}", "pure": false},
        "rpc": {"args": ["function_name", "args?"], "returns": "{data, error?}", "pure": false},
        "auth_sign_up": {"args": ["email", "password"], "returns": "{ok, data, error?}", "pure": false},
        "auth_sign_in_with_password": {"args": ["email", "password"], "returns": "{ok, data, error?}", "pure": false},
        "auth_sign_out": {"args": ["access_token?"], "returns": "{ok, data, error?}", "pure": false},
        "auth_get_user": {"args": ["access_token?"], "returns": "{ok, data, error?}", "pure": false},
        "auth_reset_password_for_email": {"args": ["email"], "returns": "{ok, data, error?}", "pure": false},
        "storage_upload": {"args": ["bucket", "path", "content"], "returns": "{ok, data, error?}", "pure": false},
        "storage_download": {"args": ["bucket", "path"], "returns": "{ok, data, error?}", "pure": false},
        "storage_list": {"args": ["bucket", "prefix?"], "returns": "{ok, data, error?}", "pure": false},
        "storage_remove": {"args": ["bucket", "[paths]"], "returns": "{ok, data, error?}", "pure": false},
        "storage_get_public_url": {"args": ["bucket", "path"], "returns": "{ok, data, error?}", "pure": false},
        "realtime_subscribe": {"args": ["channel", "table?", "event_types?", "filter?", "timeout_s?", "max_events?", "replay_from?", "fanout_group?", "consumer?"], "returns": "{ok, result:{channel,events,active,fanout_group?,consumer?}}", "pure": false},
        "realtime_unsubscribe": {"args": ["channel"], "returns": "{ok, result}", "pure": false},
        "realtime_broadcast": {"args": ["channel", "event", "payload?"], "returns": "{ok, result}", "pure": false},
        "realtime_replay": {"args": ["channel", "from_sequence_or_timestamp?", "max_events?", "timeout_s?"], "returns": "{ok, result:{channel,events}}", "pure": false},
        "realtime_get_cursor": {"args": ["channel", "fanout_group?", "consumer?"], "returns": "{ok, result:{channel,group,consumer,cursor}}", "pure": false},
        "realtime_ack": {"args": ["channel", "cursor", "fanout_group?", "consumer?"], "returns": "{ok, result:{channel,group,consumer,cursor}}", "pure": false}
      },
      "config": {
        "db_url_env": "AINL_SUPABASE_DB_URL (fallback: AINL_POSTGRES_URL)",
        "url_env": "AINL_SUPABASE_URL",
        "anon_key_env": "AINL_SUPABASE_ANON_KEY",
        "service_role_key_env": "AINL_SUPABASE_SERVICE_ROLE_KEY",
        "runtime_async_env": "AINL_RUNTIME_ASYNC (or --runtime-async)",
        "timeout_s": 8.0,
        "allow_write": false,
        "allow_tables": [],
        "allow_buckets": [],
        "allow_channels": []
      },
      "rules": [
        "db/table operations delegate to postgres adapter semantics",
        "mutating operations require allow_write=true",
        "table, bucket, and channel allowlists are enforced when configured",
        "realtime_broadcast and realtime_ack require allow_write=true",
        "realtime events normalize to {event,schema,table,record,old_record?,sequence?,timestamp?}",
        "realtime replay/fanout/cursor helpers are lightweight in-process primitives"
      ]
    },
    "fs": {
      "description": "Sandboxed file system operations",
      "targets": {
        "read": {
          "args": [
            "path"
          ],
          "returns": "string",
          "pure": false
        },
        "write": {
          "args": [
            "path",
            "content"
          ],
          "returns": "{ok, bytes}",
          "pure": false
        },
        "list": {
          "args": [
            "path"
          ],
          "returns": "[string]",
          "pure": false
        },
        "delete": {
          "args": [
            "path"
          ],
          "returns": "{ok}",
          "pure": false,
          "requires_allow_delete": true
        }
      },
      "config": {
        "sandbox_root": "required",
        "max_read_bytes": 1000000,
        "max_write_bytes": 1000000,
        "allow_extensions": [],
        "allow_delete": false
      },
      "rules": [
        "All paths must stay within sandbox_root",
        "Extension allowlist enforced when set",
        "Size limits enforced for read/write"
      ]
    },
    "email": {
      "description": "OpenClaw email check integration (only G target)",
      "targets": {
        "G": {
          "args": [],
          "returns": "[email]",
          "network": false,
          "side_effect": "reads openclaw mailbox"
        }
      },
      "returns": "List of unread email objects with fields: id, from, subject, body, ts"
    },
    "calendar": {
      "description": "OpenClaw calendar integration (only G target)",
      "targets": {
        "G": {
          "args": [],
          "returns": "[event]",
          "network": false,
          "side_effect": "reads openclaw calendar"
        }
      },
      "returns": "List of upcoming calendar events with fields: id, title, start, end, location"
    },
    "social": {
      "description": "OpenClaw web search for mentions (only G target)",
      "targets": {
        "G": {
          "args": [],
          "returns": "[mention]",
          "network": true,
          "side_effect": "calls openclaw web search"
        }
      },
      "returns": "List of mention objects with fields: id, text, ts",
      "config": {
        "query_env": "SOCIAL_MONITOR_QUERY (default: \"Steven Hooley\")",
        "count": 10
      }
    },
    "svc": {
      "description": "Infrastructure service status checks",
      "targets": {
        "caddy": {
          "args": [],
          "returns": "\"up\"|\"down\"",
          "pure": true
        },
        "cloudflared": {
          "args": [],
          "returns": "\"up\"|\"down\"",
          "pure": true
        },
        "maddy": {
          "args": [],
          "returns": "\"up\"|\"down\"",
          "pure": true
        },
        "crm": {
          "args": [],
          "returns": "\"up\"|\"down\"",
          "pure": true
        }
      }
    },
    "db": {
      "description": "Leads database adapter (CSV source)",
      "targets": {
        "F": {
          "args": [],
          "returns": "[lead]",
          "network": false,
          "side_effect": "reads leads CSV"
        }
      },
      "config": {
        "leads_csv_env": "LEADS_CSV (default: workspace/leads/lead_output.csv)"
      },
      "returns": "List of lead objects with enriched fields (name, city, phone, website, etc.)"
    },
    "cache": {
      "description": "Persistent key-value store (JSON file)",
      "targets": {
        "get": {
          "args": [
            "namespace",
            "key"
          ],
          "returns": "any",
          "pure": false
        },
        "set": {
          "args": [
            "namespace",
            "key",
            "value"
          ],
          "returns": "null",
          "pure": false
        }
      },
      "config": {
        "cache_json_env": "MONITOR_CACHE_JSON (default: /tmp/monitor_state.json)"
      }
    },
    "queue": {
      "description": "Notification queue (sends to self via OpenClaw)",
      "targets": {
        "Put": {
          "args": [
            "queue_name",
            "payload"
          ],
          "returns": "\"sent\"|\"logged\"|\"error\"",
          "pure": false
        }
      },
      "rules": [
        "Only queue 'notify' is implemented for the current monitors.",
        "Payload is formatter-driven and tolerant; examples include fields like email_count, cal_count, social_count, leads_count, health_score, failed_services, ts, but this shape is advisory rather than a strict schema."
      ]
    },
    "wasm": {
      "description": "WebAssembly module execution",
      "targets": {
        "CALL": {
          "args": [
            "module",
            "function",
            "args..."
          ],
          "returns": "any",
          "pure": false
        }
      },
      "config": {
        "modules_dir": "demo/wasm",
        "available_modules": [
          "metrics",
          "health"
        ],
        "require_wasmtime": true
      }
    },
    "extras": {
      "description": "Utility health checks: file + Docker + HTTP + backup mtime + metrics summaries",
      "targets": {
        "file_exists": {
          "args": [
            "path"
          ],
          "returns": "number",
          "pure": false
        },
        "docker_image_exists": {
          "args": [
            "image"
          ],
          "returns": "number",
          "pure": false
        },
        "http_status": {
          "args": [
            "url"
          ],
          "returns": "number",
          "network": true
        },
        "newest_backup_mtime": {
          "args": [
            "backup_dir"
          ],
          "returns": "number",
          "pure": false
        },
        "metrics": {
          "args": [
            "summary_path"
          ],
          "returns": "{run_count, ok_count, error_count, ok_ratio, runtime_versions, result_kinds, trace_op_counts, label_counts, timestamps_present}",
          "pure": false
        }
      }
    },
    "agent": {
      "description": "Local mailbox coordination for agent-to-agent tasks. Minimal surface: send_task and read_result only; no polling, discovery, or list operations.",
      "targets": {
        "send_task": {
          "args": [
            "envelope"
          ],
          "returns": "task_id (string)",
          "pure": false
        },
        "read_result": {
          "args": [
            "task_id"
          ],
          "returns": "AgentTaskResult (dict)",
          "pure": false
        }
      },
      "config": {
        "root_env": "AINL_AGENT_ROOT (default: /tmp/ainl_agents)",
        "tasks_file": "tasks/openclaw_agent_tasks.jsonl",
        "results_dir": "results/"
      },
      "notes": [
        "No read_task or list_agents verbs.",
        "Task consumption and result creation are external/orchestrator-driven."
      ]
    },
    "tiktok": {
      "description": "TikTok reports from CRM database",
      "targets": {
        "F": {
          "args": [],
          "returns": "[report]",
          "network": false,
          "side_effect": "reads TiktokReport table"
        },
        "recent": {
          "args": [
            "hours_ago?"
          ],
          "returns": "number",
          "pure": false
        },
        "videos": {
          "args": [],
          "returns": "[video]",
          "network": false,
          "side_effect": "reads TiktokVideo table"
        }
      },
      "returns": "F returns report objects; videos returns video objects with fields: id, tiktokId, title, description, processedAt, createdAt"
    },
    "memory": {
      "description": "Extension-level memory adapter for explicit execution-facing records keyed by (namespace, record_kind, record_id).",
      "targets": {
        "put": {
          "args": ["namespace", "record_kind", "record_id", "payload", "ttl_seconds?"],
          "returns": "{ok, created, updated_at}",
          "pure": false
        },
        "get": {
          "args": ["namespace", "record_kind", "record_id"],
          "returns": "{found, record|null}",
          "pure": false
        },
        "append": {
          "args": ["namespace", "record_kind", "record_id", "entry", "ttl_seconds?"],
          "returns": "{ok, updated_at}",
          "pure": false
        },
        "list": {
          "args": ["namespace", "record_kind?", "record_id_prefix?", "updated_since?"],
          "returns": "{items}",
          "pure": false
        },
        "delete": {
          "args": ["namespace", "record_kind", "record_id"],
          "returns": "{ok, deleted}",
          "pure": false
        },
        "prune": {
          "args": ["namespace?"],
          "returns": "{ok, pruned}",
          "pure": false
        }
      },
      "config": {
        "db_path_env": "AINL_MEMORY_DB (default: /tmp/ainl_memory.sqlite3)"
      },
      "notes": [
        "Extension/OpenClaw-only memory adapter; not part of the canonical AINL core.",
        "Records are typed by namespace and record_kind; record_id selects instances.",
        "payload must be a JSON object; ttl_seconds is an advisory hint only.",
        "append is intended for log-like records (e.g. daily_log.note) and will fail on non-log payloads."
      ]
    },
    "vector_memory": {
      "description": "Local JSON chunk store with keyword overlap scoring (stub semantic search; embeddings can replace scoring later).",
      "privilege_tier": "local_state",
      "destructive": false,
      "network_facing": false,
      "sandbox_safe": true,
      "targets": {
        "search": {
          "args": ["query", "limit?"],
          "returns": "[{namespace, kind, id, text, score, payload, ...}]",
          "pure": false
        },
        "list_similar": {
          "args": ["query", "limit?"],
          "returns": "[{namespace, kind, id, text, score, payload, ...}]",
          "pure": false
        },
        "upsert": {
          "args": ["namespace", "kind", "record_id", "text", "payload_json?"],
          "returns": "{ok, updated}",
          "pure": false
        }
      },
      "config": {
        "path_env": "AINL_VECTOR_MEMORY_PATH (default: .ainl_vector_memory.json)"
      },
      "notes": [
        "Canonical dotted: R vector_memory.SEARCH \"q\" [limit] ->out; upsert uses split form R vector_memory upsert ... ->out.",
        "No network; no extra dependencies."
      ]
    },
    "tool_registry": {
      "description": "Local JSON registry for named tools (metadata + optional JSON schema).",
      "privilege_tier": "local_state",
      "destructive": false,
      "network_facing": false,
      "sandbox_safe": true,
      "targets": {
        "register": {
          "args": ["name", "description", "schema_json?"],
          "returns": "{ok, name}",
          "pure": false
        },
        "list": {
          "args": [],
          "returns": "[tool]",
          "pure": false
        },
        "get": {
          "args": ["name"],
          "returns": "{found, tool}",
          "pure": false
        },
        "discover": {
          "args": [],
          "returns": "{tools: [tool]}",
          "pure": false
        }
      },
      "config": {
        "path_env": "AINL_TOOL_REGISTRY_PATH (default: .ainl_tool_registry.json)"
      },
      "notes": [
        "DISCOVER returns a TOOL.discover-style envelope.",
        "Use split form: R tool_registry list / discover / get name / register ... ->out."
      ]
    },
    "ptc_runner": {
      "description": "Optional external PTC Runner bridge for executing PTC-Lisp snippets from AINL graphs.",
      "privilege_tier": "network",
      "destructive": true,
      "network_facing": true,
      "sandbox_safe": false,
      "targets": {
        "run": {
          "args": ["lisp", "signature?", "subagent_budget?"],
          "returns": "{ok, runtime, status_code?, result, beam_metrics?, traces}",
          "pure": false
        },
        "health": {
          "args": [],
          "returns": "{ok, runtime, status_code?, result{beam_status}, beam_metrics?, traces}",
          "pure": false
        }
      },
      "config": {
        "enable_env": "AINL_ENABLE_PTC=true or --enable-adapter ptc_runner",
        "runner_url_env": "AINL_PTC_RUNNER_URL",
        "mock_env": "AINL_PTC_RUNNER_MOCK",
        "subprocess_cmd_env": "AINL_PTC_RUNNER_CMD",
        "metrics_path_env": "AINL_PTC_METRICS_PATH (optional, e.g. /metrics)"
      },
      "notes": [
        "Lowercase split form and dotted uppercase form are both supported: R ptc_runner run ... and R ptc_runner.RUN ...",
        "Health aliases are supported: R ptc_runner health and R ptc_runner status.",
        "For LangGraph hybrids, use intelligence/ptc_to_langgraph_bridge.py to generate thin bridge nodes without modifying the core emitter.",
        "Adapter remains opt-in and is not active unless explicitly enabled."
      ]
    },
    "llm_query": {
      "description": "Optional ad-hoc LLM query adapter for prompt execution from AINL graph steps.",
      "privilege_tier": "network",
      "destructive": true,
      "network_facing": true,
      "sandbox_safe": false,
      "targets": {
        "query": {
          "args": ["prompt", "model?", "max_tokens?"],
          "returns": "{ok, runtime, status_code?, result, traces}",
          "pure": false
        },
        "run": {
          "args": ["prompt", "model?", "max_tokens?"],
          "returns": "{ok, runtime, status_code?, result, traces}",
          "pure": false
        }
      },
      "config": {
        "enable_env": "AINL_ENABLE_LLM_QUERY=true or --enable-adapter llm_query",
        "runner_url_env": "AINL_LLM_QUERY_URL",
        "mock_env": "AINL_LLM_QUERY_MOCK",
        "subprocess_cmd_env": "AINL_LLM_QUERY_CMD"
      },
      "notes": [
        "Supports split and dotted forms: R llm_query query ... and R llm_query.QUERY ...",
        "Underscore-prefixed context keys are filtered before request serialization."
      ]
    }
  },
  "notes": [
    "All adapters are optional except 'core'. Enable only what's needed.",
    "Side effects are explicit: cache writes, network calls, and OpenClaw integrations are marked.",
    "For small offline models: focus on core, http, sqlite, fs, and cache. The OpenClaw-specific adapters (email, calendar, social, db, queue, svc) are specialized.",
    "Error handling: adapter errors throw; catch with If/J blocks or use safe wrappers."
  ],
  "agent": {
    "adapter": "agent.AgentAdapter",
    "capabilities": [
      "send_task",
      "read_result"
    ],
    "description": "Local mailbox coordination protocol for agent-to-agent tasks. Minimal surface: send_task and read_result only."
  }
}
