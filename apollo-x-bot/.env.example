# Copy to .env and fill. See apollo-x-bot/README.md.

X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
OPENAI_API_KEY=
PROMOTER_GATEWAY_URL=http://127.0.0.1:17301
PROMOTER_DRY_RUN=0

# SQLite paths (absolute recommended). If you point at an existing directory, the gateway uses
# <dir>/promoter_state.sqlite and <dir>/promoter_memory.sqlite automatically.
# PROMOTER_STATE_PATH=/path/to/promoter_state.sqlite
# AINL_MEMORY_DB=/path/to/promoter_memory.sqlite

# Reply cap (UTC day). Omit for default 20. Many older setups used 10 — raise if you see daily_cap skips at 10 replies.
# PROMOTER_MAX_REPLIES_PER_DAY=20
# Standalone promotional posts per UTC day (see promoter.maybe_daily_post); default 5.
# PROMOTER_MAX_ORIGINAL_POSTS_PER_DAY=5

# Read-only monitor: http://127.0.0.1:17301/v1/promoter.dashboard (disable with 0 if exposed)
PROMOTER_DASHBOARD_ENABLED=1
# Dashboard charts (SQLite audit + daily_replies); max 168 hours / 30 days
# PROMOTER_DASHBOARD_CHART_HOURS=48
# PROMOTER_DASHBOARD_CHART_DAYS=7

# Growth pack v1.3 — discovery on by default (disable with PROMOTER_DISCOVERY_ENABLED=0)
PROMOTER_MONITOR_ENABLED=0
PROMOTER_DISCOVERY_ENABLED=1
PROMOTER_DISCOVERY_FROM_SEARCH=1
PROMOTER_DISCOVERY_AUTO_FOLLOW=1
PROMOTER_DISCOVERY_AUTO_MONITOR=1
# PROMOTER_DISCOVERY_MAX_AUTHORS_PER_SEARCH=15
# PROMOTER_FOLLOWING_CACHE_TTL_SEC=3600
PROMOTER_LIKE_ENABLED=0
PROMOTER_THREAD_ENABLED=0
PROMOTER_AWARENESS_BOOST=0
PROMOTER_DISCOVERY_MIN_SCORE=7
