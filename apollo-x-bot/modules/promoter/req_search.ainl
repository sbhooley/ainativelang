# Bridge request body for executor x.search (Apollo promoter). Output: req_search
include "../../../modules/common/executor_bridge_request.ainl" as bridge_req
LENTRY:
  R core.ECHO "{\"run_id\":\"ainl-x-promoter\",\"step_id\":\"_poll\",\"executor\":\"x.search\",\"payload\":{\"query\":\"@Apollo_AINL\"},\"timeout_s\":120}" ->ainl_bridge_request_json
  Call bridge_req/ENTRY ->req_search
  J req_search
LEXIT_OK:
  J "ok"
